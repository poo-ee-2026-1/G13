// TelaTI.java
package com.monitoramento.ui;

import com.monitoramento.model.OrdemServico;
import com.monitoramento.model.Cliente;
import com.monitoramento.model.Usuario;
import com.monitoramento.dao.OrdemServicoDAO;
import com.monitoramento.dao.ClienteDAO;
import com.monitoramento.dao.EquipamentoDAO;
import com.monitoramento.service.OrdemServicoService;
import com.monitoramento.Main;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.awt.event.*;
import java.text.SimpleDateFormat;
import java.util.List;

public class TelaTI extends JFrame {
    private OrdemServicoDAO ordemServicoDAO;
    private ClienteDAO clienteDAO;
    private EquipamentoDAO equipamentoDAO;
    private OrdemServicoService osService;
    private Usuario usuarioLogado;
    
    private JTable tabelaOS;
    private DefaultTableModel tableModel;
    private JComboBox<String> comboFiltroNivel, comboFiltroStatus;
    private JButton btnAssumir, btnConcluir, btnAtualizar;
    
    public TelaTI(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.ordemServicoDAO = new OrdemServicoDAO();
        this.clienteDAO = new ClienteDAO();
        this.equipamentoDAO = new EquipamentoDAO();
        this.osService = Main.getOrdemServicoService();
        
        // Permite acesso para Técnicos, Administradores e Gerentes
        if (!usuario.getFuncao().equals("Técnico") && 
            !usuario.getFuncao().equals("Administrador") && 
            !usuario.getFuncao().equals("Gerente")) {
            JOptionPane.showMessageDialog(this, "Apenas Técnicos, Gerentes ou Administradores podem acessar o TI!");
            dispose();
            return;
        }
        
        initComponents();
        carregarOrdens();
        setLocationRelativeTo(null);
    }
    
    private void initComponents() {
        setTitle("TI - Ordens de Serviço - Usuário: " + usuarioLogado.getLogin());
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setSize(1200, 650);
        setLayout(new BorderLayout());
        
        // Painel de filtros
        JPanel painelFiltros = new JPanel(new FlowLayout(FlowLayout.LEFT));
        painelFiltros.setBorder(BorderFactory.createTitledBorder("Filtros"));
        
        painelFiltros.add(new JLabel("Nível:"));
        comboFiltroNivel = new JComboBox<>(new String[]{"TODOS", "1º Nível", "2º Nível", "3º Nível"});
        
        painelFiltros.add(new JLabel("Status:"));
        comboFiltroStatus = new JComboBox<>(new String[]{"TODAS", "ABERTA", "EM_ATENDIMENTO", "FECHADA"});
        
        JButton btnFiltrar = new JButton("Filtrar");
        JButton btnLimpar = new JButton("Limpar");
        
        btnFiltrar.addActionListener(e -> filtrarOrdens());
        btnLimpar.addActionListener(e -> {
            comboFiltroNivel.setSelectedIndex(0);
            comboFiltroStatus.setSelectedIndex(0);
            carregarOrdens();
        });
        
        painelFiltros.add(comboFiltroNivel);
        painelFiltros.add(comboFiltroStatus);
        painelFiltros.add(btnFiltrar);
        painelFiltros.add(btnLimpar);
        
        // Tabela
        String[] colunas = {"ID", "Cliente", "Equipamento", "Nível", "Status", "Motivo", "Data Abertura", "Data Fechamento"};
        tableModel = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        tabelaOS = new JTable(tableModel);
        tabelaOS.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        tabelaOS.setRowHeight(25);
        
        tabelaOS.getColumnModel().getColumn(0).setPreferredWidth(50);
        tabelaOS.getColumnModel().getColumn(1).setPreferredWidth(200);
        tabelaOS.getColumnModel().getColumn(2).setPreferredWidth(150);
        tabelaOS.getColumnModel().getColumn(3).setPreferredWidth(80);
        tabelaOS.getColumnModel().getColumn(4).setPreferredWidth(100);
        tabelaOS.getColumnModel().getColumn(5).setPreferredWidth(300);
        
        JScrollPane scrollTabela = new JScrollPane(tabelaOS);
        
        // Painel de botões
        JPanel painelBotoes = new JPanel(new FlowLayout());
        
        btnAssumir = new JButton("Assumir OS (Iniciar Atendimento)");
        btnConcluir = new JButton("Concluir OS");
        btnAtualizar = new JButton("Atualizar");
        JButton btnVoltar = new JButton("Voltar");
        
        btnAssumir.addActionListener(e -> assumirOS());
        btnConcluir.addActionListener(e -> concluirOS());
        btnAtualizar.addActionListener(e -> carregarOrdens());
        btnVoltar.addActionListener(e -> dispose());
        
        tabelaOS.getSelectionModel().addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                atualizarBotoes();
            }
        });
        
        painelBotoes.add(btnAssumir);
        painelBotoes.add(btnConcluir);
        painelBotoes.add(btnAtualizar);
        painelBotoes.add(btnVoltar);
        
        // Painel de instruções
        JPanel painelInstrucoes = new JPanel();
        painelInstrucoes.setBackground(new Color(240, 248, 255));
        JLabel lblInstrucoes = new JLabel("Instruções: Selecione uma OS aberta para atendimento. OS de 3º Nível são para instalações e reparos no sistema.");
        lblInstrucoes.setFont(new Font("Arial", Font.PLAIN, 12));
        painelInstrucoes.add(lblInstrucoes);
        
        add(painelFiltros, BorderLayout.NORTH);
        add(scrollTabela, BorderLayout.CENTER);
        add(painelBotoes, BorderLayout.SOUTH);
        add(painelInstrucoes, BorderLayout.PAGE_END);
    }
    
    private void carregarOrdens() {
        tableModel.setRowCount(0);
        List<OrdemServico> ordens = ordemServicoDAO.listarTodas();
        adicionarOrdensTabela(ordens);
    }
    
    private void filtrarOrdens() {
        String nivel = (String) comboFiltroNivel.getSelectedItem();
        String status = (String) comboFiltroStatus.getSelectedItem();
        
        List<OrdemServico> ordens = ordemServicoDAO.listarTodas();
        
        if (!"TODOS".equals(nivel)) {
            ordens = ordens.stream()
                .filter(os -> os.getTipoNivel() != null && os.getTipoNivel().equals(nivel))
                .toList();
        }
        
        if (!"TODAS".equals(status)) {
            ordens = ordens.stream()
                .filter(os -> os.getStatus() != null && os.getStatus().equals(status))
                .toList();
        }
        
        adicionarOrdensTabela(ordens);
    }
    
    private void adicionarOrdensTabela(List<OrdemServico> ordens) {
        tableModel.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy HH:mm");
        
        for (OrdemServico os : ordens) {
            Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
            String nomeCliente = cliente != null ? cliente.getNomeExibicao() : "N/A";
            
            String nomeEquipamento = "N/A";
            if (os.getIdEquipamento() > 0) {
                var equip = equipamentoDAO.buscarPorId(os.getIdEquipamento());
                if (equip != null) {
                    nomeEquipamento = equip.getMarca() + " " + equip.getModelo();
                }
            }
            
            String statusExibicao = "";
            switch (os.getStatus()) {
                case "ABERTA": statusExibicao = "ABERTA"; break;
                case "EM_ATENDIMENTO": statusExibicao = "EM ATENDIMENTO"; break;
                case "FECHADA": statusExibicao = "FECHADA"; break;
                default: statusExibicao = os.getStatus();
            }
            
            Object[] row = {
                os.getId(),
                nomeCliente,
                nomeEquipamento,
                os.getTipoNivel(),
                statusExibicao,
                os.getMotivo() != null ? (os.getMotivo().length() > 60 ? os.getMotivo().substring(0, 60) + "..." : os.getMotivo()) : "",
                os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                os.getDataFechamento() != null ? sdf.format(os.getDataFechamento()) : ""
            };
            tableModel.addRow(row);
        }
    }
    
    private void atualizarBotoes() {
        int row = tabelaOS.getSelectedRow();
        boolean selecionado = row >= 0;
        
        if (selecionado) {
            String status = (String) tableModel.getValueAt(row, 4);
            String nivel = (String) tableModel.getValueAt(row, 3);
            
            btnAssumir.setEnabled("ABERTA".equals(status));
            btnConcluir.setEnabled("EM_ATENDIMENTO".equals(status));
        } else {
            btnAssumir.setEnabled(false);
            btnConcluir.setEnabled(false);
        }
    }
    
    private void assumirOS() {
        int row = tabelaOS.getSelectedRow();
        if (row < 0) return;
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        String nivel = (String) tableModel.getValueAt(row, 3);
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Deseja assumir esta OS?\n\n" +
            "OS #" + idOS + "\n" +
            "Nível: " + nivel + "\n\n" +
            "Você será responsável pelo atendimento desta ordem.", 
            "Assumir OS", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            if (ordemServicoDAO.atualizarStatus(idOS, "EM_ATENDIMENTO")) {
                JOptionPane.showMessageDialog(this, "OS #" + idOS + " assumida com sucesso!\nStatus alterado para EM ATENDIMENTO.");
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao assumir OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void concluirOS() {
        int row = tabelaOS.getSelectedRow();
        if (row < 0) return;
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        String nivel = (String) tableModel.getValueAt(row, 3);
        
        JPanel panel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Descrição da Solução:*"), gbc);
        JTextArea txtSolucao = new JTextArea(5, 40);
        txtSolucao.setLineWrap(true);
        JScrollPane scrollSolucao = new JScrollPane(txtSolucao);
        gbc.gridy = 1;
        panel.add(scrollSolucao, gbc);
        
        gbc.gridy = 2;
        panel.add(new JLabel("Falha Identificada:*"), gbc);
        JComboBox<String> comboFalha = new JComboBox<>(new String[]{"CLIENTE", "MONITORAMENTO", "INSTALAÇÃO", "HARDWARE", "SOFTWARE"});
        gbc.gridy = 3;
        panel.add(comboFalha, gbc);
        
        // Para OS de 3º nível, opção adicional
        if ("3º Nível".equals(nivel)) {
            gbc.gridy = 4;
            panel.add(new JLabel("Observações da Instalação/Reparo:"), gbc);
            JTextArea txtObs = new JTextArea(3, 40);
            txtObs.setLineWrap(true);
            JScrollPane scrollObs = new JScrollPane(txtObs);
            gbc.gridy = 5;
            panel.add(scrollObs, gbc);
        }
        
        int result = JOptionPane.showConfirmDialog(this, panel, 
            "Concluir Ordem de Serviço", JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (result == JOptionPane.OK_OPTION) {
            String solucao = txtSolucao.getText().trim();
            if (solucao.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Descrição da solução é obrigatória!");
                return;
            }
            
            String falha = (String) comboFalha.getSelectedItem();
            
            if (ordemServicoDAO.fecharOrdemServico(idOS, solucao, falha, usuarioLogado.getId())) {
                JOptionPane.showMessageDialog(this, "OS #" + idOS + " concluída com sucesso!");
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao concluir OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
}