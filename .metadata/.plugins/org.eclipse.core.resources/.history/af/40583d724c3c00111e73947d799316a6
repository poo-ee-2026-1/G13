package com.monitoramento.util;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.SerializationFeature;
import com.fasterxml.jackson.databind.DeserializationFeature;
import com.fasterxml.jackson.datatype.jsr310.JavaTimeModule;
import java.io.File;
import java.io.IOException;
import java.util.*;

/**
 * Gerenciador de arquivos JSON para persistência de dados.
 * Substitui completamente a conexão com MySQL por armazenamento em arquivos.
 */
public class DatabaseConnection {
    private static final String DATA_DIR = "data";
    private static ObjectMapper objectMapper;
    
    static {
        objectMapper = new ObjectMapper();
        objectMapper.registerModule(new JavaTimeModule());
        objectMapper.enable(SerializationFeature.INDENT_OUTPUT);
        objectMapper.disable(SerializationFeature.WRITE_DATES_AS_TIMESTAMPS);
        objectMapper.configure(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES, false);
        
        // Criar diretório de dados se não existir
        File dataDir = new File(DATA_DIR);
        if (!dataDir.exists()) {
            dataDir.mkdirs();
            System.out.println("Diret�rio de dados criado: " + DATA_DIR);
        }
    }
    
    /**
     * Carrega uma lista de objetos de um arquivo JSON
     */
    public static <T> List<T> carregarLista(String fileName, Class<T> clazz) {
        File file = new File(DATA_DIR, fileName);
        if (!file.exists()) {
            return new ArrayList<>();
        }
        
        try {
            return objectMapper.readValue(file, objectMapper.getTypeFactory().constructCollectionType(List.class, clazz));
        } catch (IOException e) {
            System.err.println("Erro ao carregar " + fileName + ": " + e.getMessage());
            return new ArrayList<>();
        }
    }
    
    /**
     * Salva uma lista de objetos em um arquivo JSON
     */
    public static <T> void salvarLista(String fileName, List<T> lista) {
        File file = new File(DATA_DIR, fileName);
        try {
            objectMapper.writeValue(file, lista);
        } catch (IOException e) {
            System.err.println("Erro ao salvar " + fileName + ": " + e.getMessage());
        }
    }
    
    /**
     * Carrega um objeto único de um arquivo JSON
     */
    public static <T> T carregarObjeto(String fileName, Class<T> clazz) {
        File file = new File(DATA_DIR, fileName);
        if (!file.exists()) {
            try {
                return clazz.getDeclaredConstructor().newInstance();
            } catch (Exception e) {
                return null;
            }
        }
        
        try {
            return objectMapper.readValue(file, clazz);
        } catch (IOException e) {
            System.err.println("Erro ao carregar " + fileName + ": " + e.getMessage());
            return null;
        }
    }
    
    /**
     * Salva um objeto único em um arquivo JSON
     */
    public static <T> void salvarObjeto(String fileName, T objeto) {
        File file = new File(DATA_DIR, fileName);
        try {
            objectMapper.writeValue(file, objeto);
        } catch (IOException e) {
            System.err.println("Erro ao salvar " + fileName + ": " + e.getMessage());
        }
    }
    
    /**
     * Gera um novo ID para um objeto baseado na lista existente
     */
    public static int gerarNovoId(List<?> lista) {
        return lista.stream()
            .mapToInt(obj -> {
                try {
                    return (int) obj.getClass().getMethod("getId").invoke(obj);
                } catch (Exception e) {
                    return 0;
                }
            })
            .max()
            .orElse(0) + 1;
    }
    
    /**
     * Inicializa todos os arquivos JSON necessários
     */
    public static void inicializarArquivos() {
        String[] arquivos = {"clientes.json", "equipamentos.json", "usuarios.json", 
                             "departamentos.json", "medicoes.json", "ordens_servico.json"};
        
        for (String arquivo : arquivos) {
            File file = new File(DATA_DIR, arquivo);
            if (!file.exists()) {
                try {
                    objectMapper.writeValue(file, new ArrayList<>());
                    System.out.println("Arquivo criado: " + arquivo);
                } catch (IOException e) {
                    System.err.println("Erro ao criar arquivo " + arquivo + ": " + e.getMessage());
                }
            }
        }
        
        System.out.println("Sistema de arquivos JSON inicializado com sucesso!");
        System.out.println("Diret�rio de dados: " + new File(DATA_DIR).getAbsolutePath());
    }
    
    /**
     * Retorna o caminho absoluto do diretório de dados
     */
    public static String getDataDirectoryPath() {
        return new File(DATA_DIR).getAbsolutePath();
    }
    
    /**
     * Verifica se todos os arquivos necessários existem
     */
    public static boolean verificarArquivosExistentes() {
        String[] arquivos = {"clientes.json", "equipamentos.json", "usuarios.json", 
                             "departamentos.json", "medicoes.json", "ordens_servico.json"};
        
        for (String arquivo : arquivos) {
            File file = new File(DATA_DIR, arquivo);
            if (!file.exists()) {
                return false;
            }
        }
        return true;
    }
    
    /**
     * Exclui todos os arquivos de dados (cuidado!)
     */
    public static void limparTodosDados() {
        String[] arquivos = {"clientes.json", "equipamentos.json", "usuarios.json", 
                             "departamentos.json", "medicoes.json", "ordens_servico.json"};
        
        for (String arquivo : arquivos) {
            File file = new File(DATA_DIR, arquivo);
            if (file.exists()) {
                file.delete();
                System.out.println("Arquivo removido: " + arquivo);
            }
        }
        
        inicializarArquivos();
    }
    
    /**
     * Método de compatibilidade com código antigo - testa a conexão
     */
    public static void testConnection() {
        inicializarArquivos();
        System.out.println("Sistema operacional: " + System.getProperty("os.name"));
        System.out.println("Diret�rio de trabalho: " + System.getProperty("user.dir"));
        System.out.println("Armazenamento JSON funcionando corretamente!");
    }
    
    /**
     * Método de compatibilidade com código antigo - fecha conexão
     */
    public static void closeConnection() {
        System.out.println("Sistema encerrado - dados salvos em arquivos JSON");
        System.out.println("Diret�rio de dados: " + getDataDirectoryPath());
    }
    
    /**
     * Método de compatibilidade - obtém conexão (agora retorna null)
     */
    public static Object getConnection() {
        System.out.println("Usando armazenamento JSON em vez de banco de dados MySQL");
        return null;
    }
}