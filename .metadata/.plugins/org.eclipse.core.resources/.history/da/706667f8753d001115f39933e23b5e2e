    /**
     * Fecha a conexão (apenas para compatibilidade com sistema de banco de dados)
     */
    public static void closeConnection() {
        System.out.println("Sistema encerrado - dados salvos em arquivos JSON");
        System.out.println("Diretório de dados: " + getDataDirectoryPath());
    }
    
    /**
     * Retorna uma conexão (apenas para compatibilidade com sistema de banco de dados)
     * @return null (sistema usa arquivos JSON)
     */
    public static Object getConnection() {
        System.out.println("Usando armazenamento JSON em vez de banco de dados MySQL");
        return null;
    }
    
    /**
     * Obtém o ObjectMapper configurado (para uso avançado)
     * @return ObjectMapper configurado
     */
    public static ObjectMapper getObjectMapper() {
        return objectMapper;
    }
}