import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.awt.event.*;
import java.util.List;

public class TelaClientes extends JFrame {
    private JTable tabelaClientes;
    private DefaultTableModel tableModel;
    private ClienteDAO clienteDAO;
    private Usuario usuarioLogado;
    
    // Componentes do formulário
    private JTextField txtId, txtDocumento, txtNome, txtSobrenome, txtRazaoSocial, txtNomeFantasia;
    private JTextField txtLogradouro, txtNumero, txtBairro, txtCidade, txtEstado, txtCep;
    private JTextField txtTelefoneDDD, txtTelefoneNumero, txtIpCliente;
    private JComboBox<String> comboTipo;
    private JCheckBox chkMonitoramento;
    private JButton btnInserir, btnAtualizar, btnExcluir, btnLimpar, btnBuscar;
    
    public TelaClientes(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.clienteDAO = new ClienteDAO();
        initComponents();
        carregarClientes();
        setLocationRelativeTo(null);
    }
    
    private void initComponents() {
        setTitle("Gerenciamento de Clientes - Usuário: " + usuarioLogado.getLogin());
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setSize(1200, 700);
        setLayout(new BorderLayout());
        
        // Painel principal dividido
        JSplitPane splitPane = new JSplitPane(JSplitPane.VERTICAL_SPLIT);
        splitPane.setResizeWeight(0.6);
        
        // Tabela de clientes
        String[] colunas = {"ID", "Tipo", "Documento", "Nome/Razão Social", "Telefone", "IP", "Monitoramento"};
        tableModel = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        tabelaClientes = new JTable(tableModel);
        tabelaClientes.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        tabelaClientes.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseClicked(MouseEvent e) {
                carregarClienteSelecionado();
            }
        });
        
        JScrollPane scrollTabela = new JScrollPane(tabelaClientes);
        
        // Painel de formulário
        JPanel panelForm = criarPainelFormulario();
        
        splitPane.setTopComponent(scrollTabela);
        splitPane.setBottomComponent(panelForm);
        
        add(splitPane, BorderLayout.CENTER);
        
        // Barra de ferramentas
        JToolBar toolBar = new JToolBar();
        toolBar.setFloatable(false);
        
        JButton btnNovo = new JButton("Novo");
        btnNovo.addActionListener(e -> limparFormulario());
        
        JButton btnRefresh = new JButton("Atualizar");
        btnRefresh.addActionListener(e -> carregarClientes());
        
        JButton btnVoltar = new JButton("Voltar");
        btnVoltar.addActionListener(e -> dispose());
        
        toolBar.add(btnNovo);
        toolBar.add(btnRefresh);
        toolBar.add(Box.createHorizontalGlue());
        toolBar.add(btnVoltar);
        
        add(toolBar, BorderLayout.NORTH);
    }
    
