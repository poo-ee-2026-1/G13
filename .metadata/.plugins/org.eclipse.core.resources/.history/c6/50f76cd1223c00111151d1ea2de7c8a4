        txtDocumento.setText("");
        txtNome.setText("");
        txtSobrenome.setText("");
        txtRazaoSocial.setText("");
        txtNomeFantasia.setText("");
        txtLogradouro.setText("");
        txtNumero.setText("");
        txtBairro.setText("");
        txtCidade.setText("");
        txtEstado.setText("");
        txtCep.setText("");
        txtTelefoneDDD.setText("");
        txtTelefoneNumero.setText("");
        txtIpCliente.setText("");
        chkMonitoramento.setSelected(false);
        comboTipo.setSelectedIndex(0);
        txtDocumento.requestFocus();
    }
