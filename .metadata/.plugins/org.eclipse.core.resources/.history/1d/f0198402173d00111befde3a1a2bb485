    private void carregarOrcamentos() {
        modelOrcamentos.setRowCount(0);
        List<Atendimento> orcamentos = atendimentoDAO.listarPorTipo("ORCAMENTO");
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (Atendimento a : orcamentos) {
            Cliente c = clienteDAO.buscarPorId(a.getIdCliente());
            if (c != null) {
                Object[] row = {
                    a.getId(),
                    c.getNomeExibicao(),
                    extrairValorOrcamento(a.getDescricao()),
                    a.getStatus(),
                    sdf.format(a.getDataAbertura()),
                    a.getAssunto()
                };
                modelOrcamentos.addRow(row);
            }
        }
    }
    
    private void carregarOrdensInstalacao() {
        modelInstalacoes.setRowCount(0);
        List<OrdemServico> instalacoes = ordemServicoDAO.listarOrdensInstalacao();
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (OrdemServico os : instalacoes) {
            Cliente c = clienteDAO.buscarPorId(os.getIdCliente());
            if (c != null) {
                Object[] row = {
                    os.getId(),
                    c.getNomeExibicao(),
                    String.format("R$ %.2f", os.getValorTotal()),
                    os.getStatus(),
                    os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                    os.getDataFechamento() != null ? sdf.format(os.getDataFechamento()) : "",
                    os.getDataAgendamento() != null ? os.getDataAgendamento() : "---"
                };
                modelInstalacoes.addRow(row);
            }
        }
    }
    
    private void carregarOrcamentosPendentes(DefaultTableModel model) {
        List<Atendimento> orcamentos = atendimentoDAO.listarPorTipo("ORCAMENTO");
        orcamentos = orcamentos.stream()
            .filter(a -> "PENDENTE".equals(a.getStatus()))
            .toList();
        
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        for (Atendimento a : orcamentos) {
            Cliente c = clienteDAO.buscarPorId(a.getIdCliente());
            if (c != null) {
                Object[] row = {
                    a.getId(),
                    c.getNomeExibicao(),
                    extrairValorOrcamento(a.getDescricao()),
                    sdf.format(a.getDataAbertura()),
                    a.getAssunto()
                };
                model.addRow(row);
            }
        }
    }
    
    private double extrairValorOrcamento(String descricao) {
        if (descricao != null) {
            int idx = descricao.indexOf("VALOR TOTAL: R$ ");
            if (idx >= 0) {
                try {
                    String valorStr = descricao.substring(idx + 15);
                    int endIdx = valorStr.indexOf("\n");
                    if (endIdx > 0) {
                        valorStr = valorStr.substring(0, endIdx);
                    }
                    valorStr = valorStr.replace(",", ".").trim();
                    return Double.parseDouble(valorStr);
                } catch (Exception e) {
                    // Ignorar
                }
            }
        }
        return 0;
    }
    
    private void gerarOrcamento() {
        if (comboClienteOrcamento.getSelectedIndex() == -1) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente!");
            return;
        }
        
        String valorStr = txtValorOrcamento.getText().trim().replace(",", ".");
        double valor;
        try {
            valor = Double.parseDouble(valorStr);
            if (valor <= 0) {
                JOptionPane.showMessageDialog(this, "Adicione pelo menos um produto ao orçamento!");
                return;
            }
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Valor inválido!");
            return;
        }
        
        String descricaoResumida = txtDescricaoOrcamento.getText().trim();
        if (descricaoResumida.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Descrição resumida é obrigatória!");
            return;
        }
        
        String detalhes = txtDetalhesOrcamento.getText().trim();
        
        StringBuilder sbDescricao = new StringBuilder();
        sbDescricao.append("VALOR TOTAL: R$ ").append(String.format("%.2f", valor)).append("\n");
        sbDescricao.append("DESCRIÇÃO: ").append(descricaoResumida).append("\n");
        sbDescricao.append("PRODUTOS:\n");
        for (InstalacaoProduto item : produtosSelecionados) {
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
            if (produto != null) {
                sbDescricao.append("- ").append(produto.getNomeCompleto())
                         .append(": ").append(item.getQuantidade()).append(" x R$ ")
                         .append(String.format("%.2f", item.getPrecoUnitario()))
                         .append(" = R$ ").append(String.format("%.2f", item.getSubtotal())).append("\n");
            }
        }
        if (!detalhes.isEmpty()) {
            sbDescricao.append("OBSERVAÇÕES: ").append(detalhes).append("\n");
        }
        
        String selected = (String) comboClienteOrcamento.getSelectedItem();
        int idCliente = Integer.parseInt(selected.split(" - ")[0]);
        
        Atendimento orcamento = new Atendimento();
        orcamento.setIdCliente(idCliente);
        orcamento.setTipo("ORCAMENTO");
        orcamento.setAssunto("Orçamento - " + descricaoResumida);
        orcamento.setDescricao(sbDescricao.toString());
        orcamento.setPrioridade("MEDIA");
        orcamento.setIdUsuarioAbertura(usuarioLogado.getId());
        
        if (atendimentoDAO.inserir(orcamento)) {
            for (InstalacaoProduto item : produtosSelecionados) {
                item.setIdOrdemInstalacao(orcamento.getId());
                instalacaoProdutoDAO.inserir(item);
            }
            
            JOptionPane.showMessageDialog(this, "Orçamento gerado com sucesso!\nID: " + orcamento.getId());
            
            txtValorOrcamento.setText("0,00");
            txtDescricaoOrcamento.setText("");
            txtDetalhesOrcamento.setText("");
            txtEnderecoInstalacao.setText("");
            txtDataAgendamento.setText("");
            txtObservacoes.setText("");
            produtosSelecionados.clear();
            modelProdutosSelecionados.setRowCount(0);
            
            carregarOrcamentos();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao gerar orçamento!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void aprovarOrcamento(int idOrcamento, double valor) {
        Atendimento orcamento = atendimentoDAO.buscarPorId(idOrcamento);
        if (orcamento == null) return;
        
        List<InstalacaoProduto> produtosOrcamento = instalacaoProdutoDAO.listarPorOrdemInstalacao(idOrcamento);
        
        Cliente cliente = clienteDAO.buscarPorId(orcamento.getIdCliente());
        if (cliente == null) return;
        
        for (InstalacaoProduto item : produtosOrcamento) {
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
            if (produto == null || produto.getQuantidade() < item.getQuantidade()) {
                JOptionPane.showMessageDialog(this,
                    "Estoque insuficiente para o produto: " + (produto != null ? produto.getNomeCompleto() : "ID: " + item.getIdProduto()) + "\n" +
                    "Disponível: " + (produto != null ? produto.getQuantidade() : 0) + 
                    "\nSolicitado: " + item.getQuantidade(),
                    "Erro", JOptionPane.ERROR_MESSAGE);
                return;
            }
        }
        
        // Dialog para informações adicionais da instalação
        JPanel panelInfo = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panelInfo.add(new JLabel("Endereço da Instalação:"), gbc);
        JTextField txtEndereco = new JTextField(cliente.getLogradouro() + ", " + cliente.getNumero() + " - " + cliente.getBairro(), 40);
        gbc.gridx = 1;
        panelInfo.add(txtEndereco, gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        panelInfo.add(new JLabel("Data Agendamento (dd/MM/yyyy):"), gbc);
        JTextField txtDataAgend = new JTextField(15);
        gbc.gridx = 1;
        panelInfo.add(txtDataAgend, gbc);
        
        gbc.gridx = 0; gbc.gridy = 2;
        panelInfo.add(new JLabel("Observações:"), gbc);
        JTextArea txtObs = new JTextArea(3, 40);
        txtObs.setLineWrap(true);
        JScrollPane scrollObs = new JScrollPane(txtObs);
        gbc.gridx = 1;
        panelInfo.add(scrollObs, gbc);
        
        int confirm = JOptionPane.showConfirmDialog(this, panelInfo,
            "Aprovar Orçamento - Informações da Instalação", JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (confirm != JOptionPane.OK_OPTION) return;
        
        // Dar baixa no estoque
        for (InstalacaoProduto item : produtosOrcamento) {
            boolean baixaOk = produtoEstoqueDAO.darBaixaEstoque(
                item.getIdProduto(), 
                item.getQuantidade(), 
                "INSTALACAO", 
                idOrcamento,
                usuarioLogado.getId()
            );
            
            if (!baixaOk) {
                JOptionPane.showMessageDialog(this, "Erro ao dar baixa no estoque do produto ID: " + item.getIdProduto(),
                    "Erro", JOptionPane.ERROR_MESSAGE);
                return;
            }
        }
        
        // Criar Ordem de Instalação usando OrdemServico
        OrdemServico osInstalacao = new OrdemServico();
        osInstalacao.setIdCliente(cliente.getId());
        osInstalacao.setTipoOrdem("INSTALACAO");
        osInstalacao.setTipoNivel("3º Nível");
        osInstalacao.setStatus("ABERTA");
        osInstalacao.setMotivo("INSTALAÇÃO - Orçamento #" + idOrcamento + " - " + orcamento.getAssunto());
        osInstalacao.setValorTotal(valor);
        osInstalacao.setEnderecoInstalacao(txtEndereco.getText().trim());
        osInstalacao.setDataAgendamento(txtDataAgend.getText().trim());
        osInstalacao.setObservacoes(txtObs.getText().trim());
        osInstalacao.setIdAtendimentoOrigem(idOrcamento);
        osInstalacao.setDataAbertura(new Date());
        osInstalacao.setIdUsuarioAbertura(usuarioLogado.getId());
        
        StringBuilder sbProdutos = new StringBuilder();
        for (InstalacaoProduto item : produtosOrcamento) {
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
            if (produto != null) {
                sbProdutos.append(String.format("- %s: %d x R$ %.2f = R$ %.2f\n", 
                    produto.getNomeCompleto(), item.getQuantidade(), 
                    item.getPrecoUnitario(), item.getSubtotal()));
            }
        }
        osInstalacao.setProdutosInstalados(sbProdutos.toString());
        
        if (ordemServicoDAO.inserir(osInstalacao)) {
            orcamento.setStatus("CONCLUIDO");
            orcamento.setDataConclusao(new Date());
            orcamento.setIdUsuarioAtendimento(usuarioLogado.getId());
            orcamento.setIdOrdemServicoVinculada(osInstalacao.getId());
            atendimentoDAO.atualizar(orcamento);
            
            TransacaoFinanceira transacao = new TransacaoFinanceira();
            transacao.setTipo("ENTRADA");
            transacao.setNatureza("Instalação");
            transacao.setFormaPagamento("A_DEFINIR");
            transacao.setValor(valor);
            transacao.setDescricao("Instalação - Orçamento #" + idOrcamento + " - Cliente: " + cliente.getNomeExibicao());
            transacao.setStatus("PENDENTE");
            transacao.setIdCliente(cliente.getId());
            transacao.setIdOrdemServico(osInstalacao.getId());
            transacao.setIdUsuarioRegistro(usuarioLogado.getId());
            transacaoDAO.inserir(transacao);
            
            JOptionPane.showMessageDialog(this,
                "Orçamento aprovado!\n\n" +
                "Ordem de Instalação #" + osInstalacao.getId() + " criada.\n" +
                "Produtos baixados do estoque.\n" +
                "Transação financeira registrada (PENDENTE).\n\n" +
                "Agora o técnico deve realizar a instalação e concluir a ordem.",
                "Sucesso", JOptionPane.INFORMATION_MESSAGE);
            
            carregarOrdensInstalacao();
            carregarOrcamentos();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao criar Ordem de Instalação!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void recusarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para recusar!");
            return;
        }
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        String status = (String) modelOrcamentos.getValueAt(row, 3);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Este orçamento não está pendente!");
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Deseja recusar este orçamento?", 
            "Recusar Orçamento", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            Atendimento a = atendimentoDAO.buscarPorId(id);
            if (a != null) {
                a.setStatus("CANCELADO");
                a.setDataConclusao(new Date());
                a.setIdUsuarioAtendimento(usuarioLogado.getId());
                if (atendimentoDAO.atualizar(a)) {
                    JOptionPane.showMessageDialog(this, "Orçamento recusado!");
                    carregarOrcamentos();
                }
            }
        }
    }
    
    private void concluirInstalacao() {
        int row = tabelaInstalacoes.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione uma ordem de instalação para concluir!");
            return;
        }
        
        int id = (int) modelInstalacoes.getValueAt(row, 0);
        String status = (String) modelInstalacoes.getValueAt(row, 3);
        
        if (!"ABERTA".equals(status)) {
            JOptionPane.showMessageDialog(this, "Esta instalação já foi concluída!");
            return;
        }
        
        OrdemServico os = ordemServicoDAO.buscarPorId(id);
        if (os == null) return;
        
        JPanel panel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Observações da Instalação:"), gbc);
        JTextArea txtObsFinal = new JTextArea(5, 40);
        txtObsFinal.setLineWrap(true);
        JScrollPane scrollObs = new JScrollPane(txtObsFinal);
        gbc.gridy = 1;
        panel.add(scrollObs, gbc);
        
        int confirm = JOptionPane.showConfirmDialog(this, panel,
            "Concluir Instalação - OS #" + id, JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (confirm == JOptionPane.OK_OPTION) {
            String observacoes = txtObsFinal.getText().trim();
            if (observacoes.isEmpty()) {
                observacoes = "Instalação concluída com sucesso.";
            }
            
            if (ordemServicoDAO.concluirInstalacao(id, observacoes, usuarioLogado.getId())) {
                JOptionPane.showMessageDialog(this, "Instalação concluída com sucesso!\nOS #" + id + " finalizada.");
                carregarOrdensInstalacao();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao concluir instalação!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void agendarInstalacao() {
        int row = tabelaInstalacoes.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione uma ordem de instalação para agendar!");
            return;
        }
        
        int id = (int) modelInstalacoes.getValueAt(row, 0);
        OrdemServico os = ordemServicoDAO.buscarPorId(id);
        if (os == null) return;
        
        JPanel panel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Data Agendamento (dd/MM/yyyy):"), gbc);
        JTextField txtNovaData = new JTextField(os.getDataAgendamento() != null ? os.getDataAgendamento() : "", 15);
        gbc.gridx = 1;
        panel.add(txtNovaData, gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        panel.add(new JLabel("Observações:"), gbc);
        JTextArea txtObs = new JTextArea(3, 40);
        txtObs.setLineWrap(true);
        JScrollPane scrollObs = new JScrollPane(txtObs);
        gbc.gridx = 1;
        panel.add(scrollObs, gbc);
        
        int confirm = JOptionPane.showConfirmDialog(this, panel,
            "Agendar Instalação - OS #" + id, JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (confirm == JOptionPane.OK_OPTION) {
            String novaData = txtNovaData.getText().trim();
            if (!novaData.isEmpty()) {
                os.setDataAgendamento(novaData);
            }
            String observacoes = txtObs.getText().trim();
            if (!observacoes.isEmpty()) {
                String obsAtual = os.getObservacoes();
                os.setObservacoes((obsAtual != null ? obsAtual + "\n" : "") + "AGENDAMENTO: " + observacoes);
            }
            
            if (ordemServicoDAO.atualizar(os)) {
                JOptionPane.showMessageDialog(this, "Instalação agendada com sucesso!\nData: " + novaData);
                carregarOrdensInstalacao();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao agendar instalação!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void verDetalhesOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) return;
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        Atendimento a = atendimentoDAO.buscarPorId(id);
        
        if (a != null) {
            JTextArea textArea = new JTextArea(20, 60);
            textArea.setText("=== DETALHES DO ORÇAMENTO ===\n\n");
            textArea.append("ID: " + a.getId() + "\n");
            textArea.append("Cliente: " + modelOrcamentos.getValueAt(row, 1) + "\n");
            textArea.append("Valor: " + modelOrcamentos.getValueAt(row, 2) + "\n");
            textArea.append("Status: " + a.getStatus() + "\n");
            textArea.append("Data: " + modelOrcamentos.getValueAt(row, 4) + "\n");
            textArea.append("Descrição: " + a.getAssunto() + "\n\n");
            textArea.append("--- DETALHES COMPLETOS ---\n");
            textArea.append(a.getDescricao());
            
            List<InstalacaoProduto> produtos = instalacaoProdutoDAO.listarPorOrdemInstalacao(id);
            if (!produtos.isEmpty()) {
                textArea.append("\n\n--- PRODUTOS DO ORÇAMENTO ---\n");
                for (InstalacaoProduto item : produtos) {
                    ProdutoEstoque p = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
                    if (p != null) {
                        textArea.append(String.format("- %s: %d x R$ %.2f = R$ %.2f\n", 
                            p.getNomeCompleto(), item.getQuantidade(), 
                            item.getPrecoUnitario(), item.getSubtotal()));
                    }
                }
            }
            
            textArea.setEditable(false);
            
            JOptionPane.showMessageDialog(this, new JScrollPane(textArea), 
                "Detalhes do Orçamento", JOptionPane.INFORMATION_MESSAGE);
        }
    }
    
