    public TelaEstoque(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.produtoDAO = new ProdutoEstoqueDAO();
        this.movimentacaoDAO = new MovimentacaoEstoqueDAO();
        
        initComponents();
