    private void carregarClientesCombo(JComboBox<String> combo) {
        combo.removeAllItems();
        combo.addItem("SELECIONE UM CLIENTE");
        List<Cliente> clientes = clienteDAO.listarTodos();
        for (Cliente c : clientes) {
            combo.addItem(c.getId() + " - " + c.getNomeExibicao());
        }
    }
    
    private void carregarOrcamentos() {
        modelOrcamentos.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (Map<String, Object> o : orcamentos) {
            int qtdProdutos = 0;
            List<Map<String, Object>> produtos = (List<Map<String, Object>>) o.get("produtos");
            if (produtos != null) {
                qtdProdutos = produtos.size();
            }
            
            Object[] row = {
                o.get("id"),
                o.get("cliente"),
                o.get("descricao"),
                String.format("%.2f", o.get("valor")),
                o.get("status"),
                sdf.format((Date) o.get("data")),
                qtdProdutos + " itens"
            };
            modelOrcamentos.addRow(row);
        }
    }
    
    private void filtrarOrcamentos() {
        String status = (String) comboStatusOrcamento.getSelectedItem();
        String clienteSelecionado = (String) comboClienteOrcamento.getSelectedItem();
        
        modelOrcamentos.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (Map<String, Object> o : orcamentos) {
            if (!"TODOS".equals(status) && !status.equals(o.get("status"))) continue;
            if (clienteSelecionado != null && !"TODOS".equals(clienteSelecionado) && !"SELECIONE UM CLIENTE".equals(clienteSelecionado)) {
                String clienteNome = (String) o.get("cliente");
                if (!clienteNome.contains(clienteSelecionado.split(" - ")[1])) continue;
            }
            
            int qtdProdutos = 0;
            List<Map<String, Object>> produtos = (List<Map<String, Object>>) o.get("produtos");
            if (produtos != null) {
                qtdProdutos = produtos.size();
            }
            
            Object[] row = {
                o.get("id"),
                o.get("cliente"),
                o.get("descricao"),
                String.format("%.2f", o.get("valor")),
                o.get("status"),
                sdf.format((Date) o.get("data")),
                qtdProdutos + " itens"
            };
            modelOrcamentos.addRow(row);
        }
    }
    
    private void carregarDetalhesOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row >= 0) {
            int id = (int) modelOrcamentos.getValueAt(row, 0);
            for (Map<String, Object> o : orcamentos) {
                if ((int) o.get("id") == id) {
                    String status = (String) o.get("status");
                    if ("APROVADO".equals(status) || "REJEITADO".equals(status)) {
                        btnAprovar.setEnabled(false);
                        btnRejeitar.setEnabled(false);
                        btnConverterInstalacao.setEnabled("APROVADO".equals(status));
                    } else {
                        btnAprovar.setEnabled(true);
                        btnRejeitar.setEnabled(true);
                        btnConverterInstalacao.setEnabled(false);
                    }
                    break;
                }
            }
        }
    }
    
    private void adicionarProduto() {
        List<ProdutoEstoque> produtos = produtoDAO.listarAtivos();
        
        if (produtos.isEmpty()) {
            JOptionPane.showMessageDialog(this, 
                "Nenhum produto cadastrado no estoque!\nCadastre produtos primeiro.", 
                "Aviso", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        JDialog dialog = new JDialog(SwingUtilities.getWindowAncestor(this), "Selecionar Produtos", Dialog.ModalityType.APPLICATION_MODAL);
        dialog.setSize(700, 500);
        dialog.setLocationRelativeTo(this);
        dialog.setLayout(new BorderLayout());
        
        String[] colunas = {"ID", "Código", "Nome", "Preço Venda (R$)", "Estoque", "Selecionar"};
        DefaultTableModel model = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return column == 5;
            }
            
            @Override
            public Class<?> getColumnClass(int columnIndex) {
                if (columnIndex == 5) return Boolean.class;
                return super.getColumnClass(columnIndex);
            }
        };
        
        for (ProdutoEstoque p : produtos) {
            Object[] row = {
                p.getId(),
                p.getCodigo(),
                p.getNome(),
                String.format("%.2f", p.getPrecoVenda()),
                p.getQuantidade(),
                Boolean.FALSE
            };
            model.addRow(row);
        }
        
        JTable tabelaProdutos = new JTable(model);
        tabelaProdutos.setRowHeight(25);
        JScrollPane scroll = new JScrollPane(tabelaProdutos);
        
        JPanel painelBotoes = new JPanel();
        JButton btnAdicionar = new JButton("Adicionar Selecionados");
        JButton btnCancelar = new JButton("Cancelar");
        
        btnAdicionar.setBackground(COR_BOTAO_ADICIONAR);
        btnAdicionar.setForeground(Color.WHITE);
        
        btnAdicionar.addActionListener(e -> {
            for (int i = 0; i < model.getRowCount(); i++) {
                Boolean selecionado = (Boolean) model.getValueAt(i, 5);
                if (selecionado != null && selecionado) {
                    int idProduto = (int) model.getValueAt(i, 0);
                    ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                    
                    String quantidadeStr = JOptionPane.showInputDialog(dialog, 
                        "Quantidade de " + produto.getNome() + ":\nEstoque disponível: " + produto.getQuantidade(),
                        "Quantidade", JOptionPane.QUESTION_MESSAGE);
                    
                    if (quantidadeStr != null && !quantidadeStr.trim().isEmpty()) {
                        try {
                            int quantidade = Integer.parseInt(quantidadeStr.trim());
                            if (quantidade <= 0) {
                                JOptionPane.showMessageDialog(dialog, "Quantidade deve ser maior que zero!");
                                continue;
                            }
                            
                            boolean existe = false;
                            for (ProdutoOrcamento po : produtosSelecionados) {
                                if (po.getProduto().getId() == idProduto) {
                                    po.setQuantidade(po.getQuantidade() + quantidade);
                                    existe = true;
                                    break;
                                }
                            }
                            
                            if (!existe) {
                                produtosSelecionados.add(new ProdutoOrcamento(produto, quantidade));
                            }
                            
                        } catch (NumberFormatException ex) {
                            JOptionPane.showMessageDialog(dialog, "Quantidade inválida!");
                        }
                    }
                }
            }
            
            atualizarListaProdutos();
            dialog.dispose();
        });
        
        btnCancelar.addActionListener(e -> dialog.dispose());
        
        painelBotoes.add(btnAdicionar);
        painelBotoes.add(btnCancelar);
        
        dialog.add(scroll, BorderLayout.CENTER);
        dialog.add(painelBotoes, BorderLayout.SOUTH);
        dialog.setVisible(true);
    }
    
    private void removerProduto() {
        int row = tabelaProdutosOrcamento.getSelectedRow();
        if (row >= 0 && row < produtosSelecionados.size()) {
            produtosSelecionados.remove(row);
            atualizarListaProdutos();
        } else {
            JOptionPane.showMessageDialog(this, "Selecione um produto para remover!");
        }
    }
    
    private void atualizarListaProdutos() {
        modelProdutosOrcamento.setRowCount(0);
        double total = 0;
        
        for (ProdutoOrcamento po : produtosSelecionados) {
            double subtotal = po.getQuantidade() * po.getProduto().getPrecoVenda();
            total += subtotal;
            
            Object[] row = {
                po.getProduto().getNome(),
                po.getQuantidade(),
                String.format("%.2f", po.getProduto().getPrecoVenda()),
                String.format("%.2f", subtotal)
            };
            modelProdutosOrcamento.addRow(row);
        }
        
        lblTotalOrcamento.setText(String.format("R$ %.2f", total));
    }
    
    private void registrarMovimentacaoReserva(int idOrcamento, String acao) {
        for (ProdutoOrcamento po : produtosSelecionados) {
            MovimentacaoEstoque mov = new MovimentacaoEstoque();
            mov.setIdProduto(po.getProduto().getId());
            mov.setTipo("RESERVA");
            mov.setMotivo(acao);
            mov.setQuantidade(po.getQuantidade());
            mov.setPrecoUnitario(po.getProduto().getPrecoVenda());
            mov.setValorTotal(po.getQuantidade() * po.getProduto().getPrecoVenda());
            mov.setIdUsuario(usuarioLogado.getId());
            mov.setIdReferencia(idOrcamento);
            mov.setObservacao("Orçamento #" + idOrcamento + " - " + acao);
            movimentacaoDAO.inserir(mov);
        }
    }
    
    private void salvarOrcamento() {
        if (comboClienteNovo.getSelectedIndex() == -1 || "SELECIONE UM CLIENTE".equals(comboClienteNovo.getSelectedItem())) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente!");
            return;
        }
        
        String descricao = txtDescricaoOrcamento.getText().trim();
        if (descricao.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Descrição é obrigatória!");
            return;
        }
        
        if (produtosSelecionados.isEmpty()) {
            int confirm = JOptionPane.showConfirmDialog(this, 
                "Nenhum produto adicionado. Deseja salvar o orçamento mesmo assim?",
                "Aviso", JOptionPane.YES_NO_OPTION);
            if (confirm != JOptionPane.YES_OPTION) {
                return;
            }
        }
        
        double total = 0;
        for (ProdutoOrcamento po : produtosSelecionados) {
            total += po.getQuantidade() * po.getProduto().getPrecoVenda();
        }
        
        int idOrcamento = nextId++;
        
        Map<String, Object> novoOrcamento = new HashMap<>();
        novoOrcamento.put("id", idOrcamento);
        novoOrcamento.put("cliente", comboClienteNovo.getSelectedItem());
        novoOrcamento.put("descricao", descricao);
        novoOrcamento.put("valor", total);
        novoOrcamento.put("status", "PENDENTE");
        novoOrcamento.put("data", new Date());
        
        List<Map<String, Object>> produtosOrc = new ArrayList<>();
        for (ProdutoOrcamento po : produtosSelecionados) {
            Map<String, Object> prodMap = new HashMap<>();
            prodMap.put("idProduto", po.getProduto().getId());
            prodMap.put("nome", po.getProduto().getNome());
            prodMap.put("quantidade", po.getQuantidade());
            prodMap.put("precoUnitario", po.getProduto().getPrecoVenda());
            prodMap.put("subtotal", po.getQuantidade() * po.getProduto().getPrecoVenda());
            produtosOrc.add(prodMap);
        }
        novoOrcamento.put("produtos", produtosOrc);
        orcamentos.add(novoOrcamento);
        
        registrarMovimentacaoReserva(idOrcamento, "RESERVA_ORCAMENTO");
        
        if (osService != null) {
            int idCliente = Integer.parseInt(((String) comboClienteNovo.getSelectedItem()).split(" - ")[0]);
            String motivo = "ORÇAMENTO - " + descricao;
            osService.abrirOSOrcamento(idCliente, motivo, usuarioLogado.getId(), total);
        }
        
        JOptionPane.showMessageDialog(this, 
            "✅ Orçamento #" + idOrcamento + " salvo com sucesso!\n\n" +
            "Cliente: " + comboClienteNovo.getSelectedItem() + "\n" +
            "Descrição: " + descricao + "\n" +
            "Valor Total: R$ " + String.format("%.2f", total) + "\n" +
            "Produtos: " + produtosSelecionados.size() + "\n\n" +
            "Os produtos foram reservados no estoque até a aprovação do orçamento.",
            "Sucesso", JOptionPane.INFORMATION_MESSAGE);
        
        // Limpar formulário
        txtDescricaoOrcamento.setText("");
        produtosSelecionados.clear();
        atualizarListaProdutos();
        comboClienteNovo.setSelectedIndex(0);
        carregarOrcamentos();
    }
    
    private void aprovarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para aprovar!");
            return;
        }
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        String status = (String) modelOrcamentos.getValueAt(row, 4);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Apenas orçamentos pendentes podem ser aprovados!");
            return;
        }
        
        Map<String, Object> orcamentoEncontrado = null;
        for (Map<String, Object> o : orcamentos) {
            if ((int) o.get("id") == id) {
                orcamentoEncontrado = o;
                break;
            }
        }
        
        if (orcamentoEncontrado == null) {
            JOptionPane.showMessageDialog(this, "Orçamento não encontrado!");
            return;
        }
        
        List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) orcamentoEncontrado.get("produtos");
        boolean estoqueOK = true;
        StringBuilder erros = new StringBuilder();
        
        for (Map<String, Object> prodMap : produtosOrc) {
            int idProduto = (int) prodMap.get("idProduto");
            int quantidade = (int) prodMap.get("quantidade");
            ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
            
            if (produto == null) {
                erros.append("Produto ID ").append(idProduto).append(" não encontrado!\n");
                estoqueOK = false;
            } else if (produto.getQuantidade() < quantidade) {
                erros.append("Estoque insuficiente para: ").append(produto.getNome())
                     .append(" (Disponível: ").append(produto.getQuantidade())
                     .append(", Necessário: ").append(quantidade).append(")\n");
                estoqueOK = false;
            }
        }
        
        if (!estoqueOK) {
            JOptionPane.showMessageDialog(this, 
                "Não foi possível aprovar o orçamento devido a problemas de estoque:\n\n" + erros.toString(),
                "Estoque Insuficiente", JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Aprovar orçamento #" + id + "?\n\n" +
            "Esta ação irá:\n" +
            "1. Dar baixa nos produtos do estoque\n" +
            "2. Registrar a venda\n" +
            "3. O orçamento não poderá mais ser alterado\n\n" +
            "Deseja continuar?",
            "Aprovar Orçamento", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            for (Map<String, Object> prodMap : produtosOrc) {
                int idProduto = (int) prodMap.get("idProduto");
                int quantidade = (int) prodMap.get("quantidade");
                double precoUnitario = (double) prodMap.get("precoUnitario");
                ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                
                if (produto != null) {
                    produto.setQuantidade(produto.getQuantidade() - quantidade);
                    produtoDAO.atualizar(produto);
                    
                    MovimentacaoEstoque mov = new MovimentacaoEstoque();
                    mov.setIdProduto(idProduto);
                    mov.setTipo("SAIDA");
                    mov.setMotivo("VENDA");
                    mov.setQuantidade(quantidade);
                    mov.setPrecoUnitario(precoUnitario);
                    mov.setValorTotal(quantidade * precoUnitario);
                    mov.setIdUsuario(usuarioLogado.getId());
                    mov.setIdReferencia(id);
                    mov.setObservacao("Orçamento #" + id + " aprovado");
                    movimentacaoDAO.inserir(mov);
                }
            }
            
            for (Map<String, Object> o : orcamentos) {
                if ((int) o.get("id") == id) {
                    o.put("status", "APROVADO");
                    break;
                }
            }
            
            JOptionPane.showMessageDialog(this, "Orçamento #" + id + " aprovado com sucesso!\n\n" +
                "Estoque atualizado e venda registrada.");
            carregarOrcamentos();
            
            int converter = JOptionPane.showConfirmDialog(this,
                "Deseja converter este orçamento aprovado em uma Ordem de Instalação?",
                "Converter para Instalação", JOptionPane.YES_NO_OPTION);
            
            if (converter == JOptionPane.YES_OPTION) {
                converterParaInstalacao();
            }
        }
    }
    
    private void rejeitarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para rejeitar!");
            return;
        }
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        String status = (String) modelOrcamentos.getValueAt(row, 4);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Apenas orçamentos pendentes podem ser rejeitados!");
            return;
        }
        
        String motivo = JOptionPane.showInputDialog(this, "Motivo da rejeição:", "Rejeitar Orçamento", JOptionPane.QUESTION_MESSAGE);
        if (motivo == null) return;
        
        for (Map<String, Object> o : orcamentos) {
            if ((int) o.get("id") == id) {
                List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) o.get("produtos");
                for (Map<String, Object> prodMap : produtosOrc) {
                    int idProduto = (int) prodMap.get("idProduto");
                    int quantidade = (int) prodMap.get("quantidade");
                    double precoUnitario = (double) prodMap.get("precoUnitario");
                    
                    MovimentacaoEstoque mov = new MovimentacaoEstoque();
                    mov.setIdProduto(idProduto);
                    mov.setTipo("CANCELAMENTO_RESERVA");
                    mov.setMotivo("REJEICAO");
                    mov.setQuantidade(quantidade);
                    mov.setPrecoUnitario(precoUnitario);
                    mov.setValorTotal(quantidade * precoUnitario);
                    mov.setIdUsuario(usuarioLogado.getId());
                    mov.setIdReferencia(id);
                    mov.setObservacao("Orçamento #" + id + " rejeitado - Motivo: " + motivo);
                    movimentacaoDAO.inserir(mov);
                }
                
                o.put("status", "REJEITADO");
                o.put("motivoRejeicao", motivo);
                break;
            }
        }
        
        JOptionPane.showMessageDialog(this, "Orçamento #" + id + " rejeitado!\nMotivo: " + motivo +
            "\n\nA reserva de produtos foi cancelada.");
        carregarOrcamentos();
    }
    
    private void converterParaInstalacao() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para converter em instalação!");
            return;
        }
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        String status = (String) modelOrcamentos.getValueAt(row, 4);
        
        if (!"APROVADO".equals(status)) {
            JOptionPane.showMessageDialog(this, "Apenas orçamentos aprovados podem ser convertidos em instalação!");
            return;
        }
        
        Map<String, Object> orcamento = null;
        for (Map<String, Object> o : orcamentos) {
            if ((int) o.get("id") == id) {
                orcamento = o;
                break;
            }
        }
        
        if (orcamento == null) {
            JOptionPane.showMessageDialog(this, "Orçamento não encontrado!");
            return;
        }
        
        String clienteStr = (String) orcamento.get("cliente");
        double valorTotal = (double) orcamento.get("valor");
        String descricao = (String) orcamento.get("descricao");
        
        // Extrair ID do cliente
        int idCliente;
        try {
            idCliente = Integer.parseInt(clienteStr.split(" - ")[0]);
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Erro ao identificar cliente!");
            return;
        }
        
        // Verificar se cliente já possui OS aberta
        if (osService != null && osService.clientePossuiOSAberta(idCliente)) {
            JOptionPane.showMessageDialog(this, 
                "❌ Não foi possível criar a Ordem de Instalação!\n\n" +
                "O cliente já possui uma OS em aberto.\n" +
                "Feche a OS existente antes de converter este orçamento.", 
                "OS Existente", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        // Solicitar endereço de instalação
        String enderecoInstalacao = JOptionPane.showInputDialog(this, 
            "Informe o endereço de instalação:", 
            "Endereço de Instalação", 
            JOptionPane.QUESTION_MESSAGE);
        
        if (enderecoInstalacao == null || enderecoInstalacao.trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Endereço de instalação é obrigatório!");
            return;
        }
        
        // Solicitar data de agendamento
        JSpinner spDataAgendamento = new JSpinner(new SpinnerDateModel());
        JSpinner.DateEditor editor = new JSpinner.DateEditor(spDataAgendamento, "dd/MM/yyyy");
        spDataAgendamento.setEditor(editor);
        spDataAgendamento.setValue(new Date());
        
        int resultData = JOptionPane.showConfirmDialog(this, spDataAgendamento, 
            "Selecione a data de agendamento:", 
            JOptionPane.OK_CANCEL_OPTION);
        
        if (resultData != JOptionPane.OK_OPTION) return;
        
        Date dataAgendamento = (Date) spDataAgendamento.getValue();
        
        // Criar a Ordem de Instalação
        OrdemServico os = null;
        
        if (osService != null) {
            String motivo = "INSTALAÇÃO - Orçamento #" + id + " aprovado - " + descricao;
            
            os = osService.abrirOSInstalacaoCompleta(
                idCliente, 
                motivo, 
                usuarioLogado.getId(), 
                valorTotal, 
                enderecoInstalacao, 
                dataAgendamento,
                descricao,
                "Orçamento #" + id + " convertido em instalação"
            );
        }
        
        // Fallback: criar OS diretamente no DAO
        if (os == null) {
            os = new OrdemServico();
            os.setIdCliente(idCliente);
            os.setIdEquipamento(0);
            os.setTipoNivel("1º Nível");
            os.setStatus("ABERTA");
            os.setMotivo("INSTALAÇÃO - Orçamento #" + id + " aprovado - " + descricao);
            os.setDataAbertura(new Date());
            os.setIdUsuarioAbertura(usuarioLogado.getId());
            os.setTipoOs("INSTALACAO");
            os.setTipoOrdem("INSTALACAO");
            os.setDepartamentoOrigem("VENDAS");
            os.setValorTotal(valorTotal);
            os.setEnderecoInstalacao(enderecoInstalacao);
            os.setDataAgendamento(dataAgendamento);
            os.setDescricaoSolucao(descricao);
            os.setObservacoes("Orçamento #" + id + " convertido em instalação");
            
            if (ordemServicoDAO.inserir(os)) {
                // Sucesso
            } else {
                os = null;
            }
        }
        
        if (os != null && os.getId() > 0) {
            // Adicionar os produtos do orçamento à instalação
            List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) orcamento.get("produtos");
            
            for (Map<String, Object> prodMap : produtosOrc) {
                int idProduto = (int) prodMap.get("idProduto");
                int quantidade = (int) prodMap.get("quantidade");
                double precoUnitario = (double) prodMap.get("precoUnitario");
                
                ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                if (produto != null) {
                    InstalacaoProduto item = new InstalacaoProduto();
                    item.setIdOrdemInstalacao(os.getId());
                    item.setIdProduto(idProduto);
                    item.setNomeProduto(produto.getNome());
                    item.setQuantidade(quantidade);
                    item.setPrecoUnitario(precoUnitario);
                    item.setSubtotal(quantidade * precoUnitario);
                    instalacaoProdutoDAO.inserir(item);
                }
            }
            
            JOptionPane.showMessageDialog(this, 
                "✅ Orçamento #" + id + " convertido para Ordem de Instalação #" + os.getId() + "!\n\n" +
                "Cliente: " + clienteStr + "\n" +
                "Valor: R$ " + String.format("%.2f", valorTotal) + "\n" +
                "Endereço: " + enderecoInstalacao + "\n" +
                "Data Agendamento: " + new SimpleDateFormat("dd/MM/yyyy").format(dataAgendamento) + "\n\n" +
                "Acesse a tela 'Ordem de Instalação (ST)' no menu Vendas para gerenciar.",
                "Conversão Realizada", JOptionPane.INFORMATION_MESSAGE);
            
            carregarOrcamentos();
        } else {
            JOptionPane.showMessageDialog(this, 
                "❌ Erro ao criar Ordem de Instalação!\n" +
                "Verifique se o cliente não possui outra OS em aberto.", 
                "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private class ProdutoOrcamento {
        private ProdutoEstoque produto;
        private int quantidade;
        
        public ProdutoOrcamento(ProdutoEstoque produto, int quantidade) {
            this.produto = produto;
            this.quantidade = quantidade;
        }
        
        public ProdutoEstoque getProduto() { return produto; }
        public int getQuantidade() { return quantidade; }
        public void setQuantidade(int quantidade) { this.quantidade = quantidade; }
    }
