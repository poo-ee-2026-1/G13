    private OrdemServico abrirOrdemServico(int idCliente, String motivo, String tipoOs, 
                                            String departamentoOrigem, boolean automatica) {
        return abrirOrdemServico(idCliente, motivo, tipoOs, departamentoOrigem, automatica, 0);
    }
    
    private OrdemServico abrirOrdemServico(int idCliente, String motivo, String tipoOs, 
                                            String departamentoOrigem, boolean automatica, int idUsuario) {
        List<OrdemServico> ordensAbertas = ordemServicoDAO.buscarOrdensAbertasPorCliente(idCliente);
        if (!ordensAbertas.isEmpty()) {
            System.out.println("Cliente " + idCliente + " já possui OS aberta: " + ordensAbertas.get(0).getId());
            return ordensAbertas.get(0);
        }
        
        Cliente cliente = clienteDAO.buscarPorId(idCliente);
        if (cliente == null) {
            System.err.println("Cliente não encontrado: " + idCliente);
            return null;
        }
        
        List<Equipamento> equipamentos = equipamentoDAO.buscarPorCliente(idCliente);
        
        OrdemServico os = new OrdemServico();
        os.setIdCliente(idCliente);
        os.setIdEquipamento(equipamentos.isEmpty() ? 0 : equipamentos.get(0).getId());
        os.setTipoNivel("1º Nível");
        os.setStatus("ABERTA");
        os.setMotivo(motivo);
        os.setDataAbertura(new Date());
        os.setTipoOs(tipoOs);
        os.setDepartamentoOrigem(departamentoOrigem);
        
        if (automatica) {
            os.setIdUsuarioAbertura(0);
        } else {
            os.setIdUsuarioAbertura(idUsuario);
        }
        
        if ("INSTALACAO".equals(tipoOs)) {
            os.setTipoOrdem("INSTALACAO");
        } else if ("ORCAMENTO".equals(tipoOs)) {
            os.setTipoOrdem("ORCAMENTO");
        } else {
            os.setTipoOrdem("SERVICO");
        }
        
        boolean inserido = ordemServicoDAO.inserir(os);
        if (inserido) {
            adicionarNaFilaPorNivel(os);
            notificarOSCriada(os);
            System.out.println("OS #" + os.getId() + " aberta para cliente " + idCliente + 
                             " - Tipo: " + tipoOs + " - Motivo: " + motivo + 
                             (automatica ? " (Automática)" : " (Manual)"));
            return os;
        }
        
        return null;
    }
    
    // MÉTODOS DE ESCALONAMENTO
    public boolean escalarParaSegundoNivel(int idOS) {
        return escalarOrdem(idOS, "2º Nível");
    }
    
    public boolean escalarParaTerceiroNivel(int idOS) {
        return escalarOrdem(idOS, "3º Nível");
    }
    
    private boolean escalarOrdem(int idOS, String novoNivel) {
        OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
        if (os == null) {
            System.err.println("OS não encontrada: " + idOS);
            return false;
        }
        
        if (!"ABERTA".equals(os.getStatus())) {
            System.err.println("OS não está aberta: " + idOS);
            return false;
        }
        
        String nivelAtual = os.getTipoNivel();
        
        if ("1º Nível".equals(nivelAtual) && "2º Nível".equals(novoNivel)) {
            // OK
        } else if ("2º Nível".equals(nivelAtual) && "3º Nível".equals(novoNivel)) {
            // OK
        } else {
            System.err.println("Escalação inválida de " + nivelAtual + " para " + novoNivel);
            return false;
        }
        
        os.setTipoNivel(novoNivel);
        boolean atualizado = ordemServicoDAO.atualizar(os);
        
        if (atualizado) {
            if ("1º Nível".equals(nivelAtual)) {
                filaOSPrimeiroNivel.remove(os);
            } else if ("2º Nível".equals(nivelAtual)) {
                filaOSSegundoNivel.remove(os);
            }
            
            if ("2º Nível".equals(novoNivel)) {
                filaOSSegundoNivel.add(os);
            } else if ("3º Nível".equals(novoNivel)) {
                filaOSTerceiroNivel.add(os);
            }
            
            notificarOSEscalada(os);
            System.out.println("OS #" + idOS + " escalada para " + novoNivel);
            return true;
        }
        
        return false;
    }
    
    // MÉTODOS DE FECHAMENTO
    public boolean fecharOrdemServico(int idOS, String descricaoSolucao, String falhaIdentificada, int idUsuario) {
        OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
        if (os == null) {
            System.err.println("OS não encontrada: " + idOS);
            return false;
        }
        
        if (!"ABERTA".equals(os.getStatus())) {
            System.err.println("OS não está aberta: " + idOS);
            return false;
        }
        
        boolean fechado = ordemServicoDAO.fecharOrdemServico(idOS, descricaoSolucao, falhaIdentificada, idUsuario);
        
        if (fechado) {
            filaOSPrimeiroNivel.remove(os);
            filaOSSegundoNivel.remove(os);
            filaOSTerceiroNivel.remove(os);
            notificarOSFechada(os);
            System.out.println("OS #" + idOS + " fechada por usuário " + idUsuario);
            return true;
        }
        
        return false;
    }
    
