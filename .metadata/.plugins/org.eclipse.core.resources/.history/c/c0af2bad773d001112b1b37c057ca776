    public Map<String, Integer> getEstatisticasPorMotivo() {
        Map<String, Integer> estatisticas = new HashMap<>();
        List<OrdemServico> todas = ordemServicoDAO.listarTodas();
        
        for (OrdemServico os : todas) {
            String motivo = os.getMotivo();
            if (motivo != null && motivo.length() > 30) {
                motivo = motivo.substring(0, 30) + "...";
            }
            estatisticas.put(motivo, estatisticas.getOrDefault(motivo, 0) + 1);
        }
        
        return estatisticas;
    }
    
    public Map<String, Integer> getEstatisticasPorFalha() {
        Map<String, Integer> estatisticas = new HashMap<>();
        List<OrdemServico> fechadas = ordemServicoDAO.buscarPorStatus("FECHADA");
        
        for (OrdemServico os : fechadas) {
            String falha = os.getFalhaIdentificada();
            if (falha != null && !falha.isEmpty()) {
                estatisticas.put(falha, estatisticas.getOrDefault(falha, 0) + 1);
            }
        }
        
        return estatisticas;
    }
    
