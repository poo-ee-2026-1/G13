        btnSalvar.setForeground(Color.WHITE);
        btnSalvar.setFont(BOTAO_PADRAO_FONT);
        btnSalvar.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        btnCancelar.setPreferredSize(BOTAO_PADRAO_SIZE);
        btnCancelar.setBackground(Color.GRAY);
        btnCancelar.setForeground(Color.WHITE);
        btnCancelar.setFont(BOTAO_PADRAO_FONT);
        btnCancelar.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        btnSalvar.addActionListener(e -> {
            if (comboCliente.getSelectedIndex() == -1 || "SELECIONE UM CLIENTE".equals(comboCliente.getSelectedItem())) {
                JOptionPane.showMessageDialog(dialog, "Selecione um cliente!");
                return;
            }
            
            String descricao = txtDescricao.getText().trim();
            if (descricao.isEmpty()) {
                JOptionPane.showMessageDialog(dialog, "Descrição é obrigatória!");
                return;
            }
            
            if (produtosSelecionados.isEmpty()) {
                int confirm = JOptionPane.showConfirmDialog(dialog, 
                    "Nenhum produto adicionado. Deseja salvar o orçamento mesmo assim?",
                    "Aviso", JOptionPane.YES_NO_OPTION);
                if (confirm != JOptionPane.YES_OPTION) {
                    return;
                }
            }
            
            double total = 0;
            for (ProdutoOrcamento po : produtosSelecionados) {
                total += po.getQuantidade() * po.getProduto().getPrecoVenda();
            }
            
            int idOrcamento = nextId++;
            
            Map<String, Object> novoOrcamento = new HashMap<>();
            novoOrcamento.put("id", idOrcamento);
            novoOrcamento.put("cliente", comboCliente.getSelectedItem());
            novoOrcamento.put("descricao", descricao);
            novoOrcamento.put("valor", total);
            novoOrcamento.put("status", "PENDENTE");
            novoOrcamento.put("data", new Date());
            
            List<Map<String, Object>> produtosOrc = new ArrayList<>();
            for (ProdutoOrcamento po : produtosSelecionados) {
                Map<String, Object> prodMap = new HashMap<>();
                prodMap.put("idProduto", po.getProduto().getId());
                prodMap.put("nome", po.getProduto().getNome());
                prodMap.put("quantidade", po.getQuantidade());
                prodMap.put("precoUnitario", po.getProduto().getPrecoVenda());
                prodMap.put("subtotal", po.getQuantidade() * po.getProduto().getPrecoVenda());
                produtosOrc.add(prodMap);
            }
            novoOrcamento.put("produtos", produtosOrc);
            orcamentos.add(novoOrcamento);
            
            salvarOrcamentosNoArquivo();
            registrarMovimentacaoReserva(idOrcamento, produtosSelecionados, "RESERVA_ORCAMENTO");
            
            if (osService != null) {
                int idCliente = Integer.parseInt(((String) comboCliente.getSelectedItem()).split(" - ")[0]);
                String motivo = "ORÇAMENTO - " + descricao;
                osService.abrirOSOrcamento(idCliente, motivo, usuarioLogado.getId(), total);
            }
            
            JOptionPane.showMessageDialog(dialog, 
                "✅ Orçamento #" + idOrcamento + " salvo com sucesso!\n\n" +
                "Cliente: " + comboCliente.getSelectedItem() + "\n" +
                "Descrição: " + descricao + "\n" +
                "Valor Total: R$ " + String.format("%.2f", total) + "\n" +
                "Produtos: " + produtosSelecionados.size(),
                "Sucesso", JOptionPane.INFORMATION_MESSAGE);
            
            dialog.dispose();
            carregarOrcamentos();
        });
        
        btnCancelar.addActionListener(e -> dialog.dispose());
        
        painelBotoes.add(btnSalvar);
        painelBotoes.add(btnCancelar);
        
        dialog.add(painelPrincipal, BorderLayout.CENTER);
        dialog.add(painelBotoes, BorderLayout.SOUTH);
        dialog.setVisible(true);
    }
    
    private void adicionarProdutoDialog(JDialog dialog, List<ProdutoOrcamento> produtosSelecionados, 
                                        DefaultTableModel modelProdutos, JLabel lblTotal) {
        List<ProdutoEstoque> produtos = produtoDAO.listarAtivos();
        
        if (produtos.isEmpty()) {
            JOptionPane.showMessageDialog(dialog, 
                "Nenhum produto cadastrado no estoque!\nCadastre produtos primeiro.", 
                "Aviso", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        JDialog prodDialog = new JDialog(dialog, "Selecionar Produtos", Dialog.ModalityType.APPLICATION_MODAL);
        prodDialog.setSize(700, 500);
        prodDialog.setLocationRelativeTo(dialog);
        prodDialog.setLayout(new BorderLayout());
        
        String[] colunas = {"ID", "Código", "Nome", "Preço Venda (R$)", "Estoque", "Selecionar"};
        DefaultTableModel model = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return column == 5;
            }
            
            @Override
            public Class<?> getColumnClass(int columnIndex) {
                if (columnIndex == 5) return Boolean.class;
                return super.getColumnClass(columnIndex);
            }
        };
        
        for (ProdutoEstoque p : produtos) {
            Object[] row = {
                p.getId(),
                p.getCodigo(),
                p.getNome(),
                String.format("%.2f", p.getPrecoVenda()),
                p.getQuantidade(),
                Boolean.FALSE
            };
            model.addRow(row);
        }
        
        JTable tabelaProdutos = new JTable(model);
        tabelaProdutos.setRowHeight(25);
        JScrollPane scroll = new JScrollPane(tabelaProdutos);
        
        JPanel painelBotoes = new JPanel();
        JButton btnAdicionar = new JButton("Adicionar Selecionados");
        JButton btnCancelar = new JButton("Cancelar");
        
        btnAdicionar.setBackground(COR_BOTAO_APROVAR);
        btnAdicionar.setForeground(Color.WHITE);
        btnAdicionar.setFont(BOTAO_PADRAO_FONT);
        
        btnAdicionar.addActionListener(e -> {
            for (int i = 0; i < model.getRowCount(); i++) {
                Boolean selecionado = (Boolean) model.getValueAt(i, 5);
                if (selecionado != null && selecionado) {
                    int idProduto = (int) model.getValueAt(i, 0);
                    ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                    
                    String quantidadeStr = JOptionPane.showInputDialog(prodDialog, 
                        "Quantidade de " + produto.getNome() + ":\nEstoque disponível: " + produto.getQuantidade(),
                        "Quantidade", JOptionPane.QUESTION_MESSAGE);
                    
                    if (quantidadeStr != null && !quantidadeStr.trim().isEmpty()) {
                        try {
                            int quantidade = Integer.parseInt(quantidadeStr.trim());
                            if (quantidade <= 0) {
                                JOptionPane.showMessageDialog(prodDialog, "Quantidade deve ser maior que zero!");
                                continue;
                            }
                            
                            boolean existe = false;
                            for (ProdutoOrcamento po : produtosSelecionados) {
                                if (po.getProduto().getId() == idProduto) {
                                    po.setQuantidade(po.getQuantidade() + quantidade);
                                    existe = true;
                                    break;
                                }
                            }
                            
                            if (!existe) {
                                produtosSelecionados.add(new ProdutoOrcamento(produto, quantidade));
                            }
                            
                        } catch (NumberFormatException ex) {
                            JOptionPane.showMessageDialog(prodDialog, "Quantidade inválida!");
                        }
                    }
                }
            }
            
            atualizarListaProdutosDialog(modelProdutos, produtosSelecionados, lblTotal);
            prodDialog.dispose();
        });
        
        btnCancelar.addActionListener(e -> prodDialog.dispose());
        
        painelBotoes.add(btnAdicionar);
        painelBotoes.add(btnCancelar);
        
        prodDialog.add(scroll, BorderLayout.CENTER);
        prodDialog.add(painelBotoes, BorderLayout.SOUTH);
        prodDialog.setVisible(true);
    }
    
    private void atualizarListaProdutosDialog(DefaultTableModel modelProdutos, 
                                              List<ProdutoOrcamento> produtosSelecionados, 
                                              JLabel lblTotal) {
        modelProdutos.setRowCount(0);
        double total = 0;
        
        for (ProdutoOrcamento po : produtosSelecionados) {
            double subtotal = po.getQuantidade() * po.getProduto().getPrecoVenda();
            total += subtotal;
            
            Object[] row = {
                po.getProduto().getNome(),
                po.getQuantidade(),
                String.format("%.2f", po.getProduto().getPrecoVenda()),
                String.format("%.2f", subtotal)
            };
            modelProdutos.addRow(row);
        }
        
        lblTotal.setText(String.format("R$ %.2f", total));
    }
    
