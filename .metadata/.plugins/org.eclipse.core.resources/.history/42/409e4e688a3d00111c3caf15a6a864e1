package com.monitoramento.ui;

import com.monitoramento.model.Usuario;
import com.monitoramento.service.MonitoramentoService;
import com.monitoramento.service.OrdemServicoService;
import com.monitoramento.dao.ClienteDAO;
import com.monitoramento.Main;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import javax.swing.table.DefaultTableCellRenderer;
import java.awt.*;
import java.awt.event.*;
import java.util.*;
import java.util.Timer;

public class TelaMonitoramento extends JPanel {
    private JTable tabelaMonitoramento;
    private DefaultTableModel tableModel;
    private JLabel lblStatusConexao;
    private Timer timerAtualizacao;
    private MonitoramentoService monitoramentoService;
    private OrdemServicoService ordemServicoService;
    private Usuario usuarioLogado;
    private boolean pausado = false;
    
    public TelaMonitoramento(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.monitoramentoService = Main.getMonitoramentoService();
        this.ordemServicoService = Main.getOrdemServicoService();
        
        initComponents();
        iniciarMonitoramento();
        carregarClientesMonitorados();
    }
    
    private void initComponents() {
        setLayout(new BorderLayout());
        
        // Painel de controle
        JPanel painelControle = new JPanel(new FlowLayout(FlowLayout.LEFT));
        painelControle.setBorder(BorderFactory.createTitledBorder("Controle"));
        
        JButton btnAtualizar = new JButton("Atualizar (F5)");
        JButton btnPausar = new JButton("Pausar (F8)");
        JButton btnAbrirOS = new JButton("Abrir OS (F2)");
        JButton btnFecharOS = new JButton("Fechar OS (F4)");
        
        lblStatusConexao = new JLabel("● CONECTADO");
        lblStatusConexao.setFont(new Font("Arial", Font.BOLD, 12));
        lblStatusConexao.setForeground(new Color(0, 100, 0));
        
        btnAtualizar.addActionListener(e -> carregarClientesMonitorados());
        btnPausar.addActionListener(e -> togglePausa());
        btnAbrirOS.addActionListener(e -> abrirOSManual());
        btnFecharOS.addActionListener(e -> fecharOSManual());
        
        painelControle.add(btnAtualizar);
        painelControle.add(btnPausar);
        painelControle.add(btnAbrirOS);
        painelControle.add(btnFecharOS);
        painelControle.add(Box.createHorizontalStrut(20));
        painelControle.add(lblStatusConexao);
        
        // Tabela
        String[] colunas = {"ID_CLIENTE", "CLIENTE", "EQUIPAMENTO", "ESTADO DA REDE", "TENSÃO (V)", 
                           "MAIOR TENSÃO (V)", "MENOR TENSÃO (V)", "SITUAÇÃO DA REDE", 
                           "DISPONIBILIDADE"};
        tableModel = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        tabelaMonitoramento = new JTable(tableModel);
        tabelaMonitoramento.setRowHeight(30);
        tabelaMonitoramento.setFont(new Font("Arial", Font.PLAIN, 12));
        
        tabelaMonitoramento.getColumnModel().getColumn(3).setCellRenderer(new EstadoRedeRenderer());
        tabelaMonitoramento.getColumnModel().getColumn(7).setCellRenderer(new SituacaoRedeRenderer());
        
        // Ocultar a coluna ID_CLIENTE (índice 0)
        tabelaMonitoramento.getColumnModel().getColumn(0).setMinWidth(0);
        tabelaMonitoramento.getColumnModel().getColumn(0).setMaxWidth(0);
        tabelaMonitoramento.getColumnModel().getColumn(0).setWidth(0);
        
        JScrollPane scrollPane = new JScrollPane(tabelaMonitoramento);
        
        // Painel de informações
        JPanel painelInfo = new JPanel(new FlowLayout(FlowLayout.LEFT));
        JLabel lblInfo = new JLabel("Atalhos: F2=Abrir OS | F4=Fechar OS | F5=Atualizar | F8=Pausar");
        lblInfo.setFont(new Font("Arial", Font.PLAIN, 10));
        painelInfo.add(lblInfo);
        
        add(painelControle, BorderLayout.NORTH);
        add(scrollPane, BorderLayout.CENTER);
        add(painelInfo, BorderLayout.SOUTH);
        
        configurarAtalhos();
