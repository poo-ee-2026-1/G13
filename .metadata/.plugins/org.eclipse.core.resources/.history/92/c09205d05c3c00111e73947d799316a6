package com.monitoramento.ui;

import com.monitoramento.model.OrdemServico;
import com.monitoramento.model.Cliente;
import com.monitoramento.model.Usuario;
import com.monitoramento.service.OrdemServicoService;
import com.monitoramento.dao.ClienteDAO;
import com.monitoramento.dao.EquipamentoDAO;
import com.monitoramento.dao.UsuarioDAO;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.awt.event.*;
import java.text.SimpleDateFormat;
import java.util.List;

public class TelaOrdensServico extends JFrame implements OrdemServicoService.OSListener {
    private JTable tabelaOrdens;
    private DefaultTableModel tableModel;
    private OrdemServicoService osService;
    private ClienteDAO clienteDAO;
    private EquipamentoDAO equipamentoDAO;
    private UsuarioDAO usuarioDAO;
    private Usuario usuarioLogado;
    
    private JComboBox<String> comboFiltroStatus;
    private JTextField txtBuscaCliente;
    private JButton btnFiltrar, btnLimparFiltro;
    private JButton btnEscalar, btnFechar, btnAtualizar;
    
    public TelaOrdensServico(Usuario usuario, OrdemServicoService osService) {
        this.usuarioLogado = usuario;
        this.osService = osService;
        this.clienteDAO = new ClienteDAO();
        this.equipamentoDAO = new EquipamentoDAO();
        this.usuarioDAO = new UsuarioDAO();
        
        osService.addOSListener(this);
        
        initComponents();
        carregarOrdens();
        setLocationRelativeTo(null);
    }
    
    private void initComponents() {
        setTitle("Ordens de Serviço - Usuário: " + usuarioLogado.getLogin());
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setSize(1200, 700);
        setLayout(new BorderLayout());
        
        // Painel de filtros
        JPanel painelFiltros = new JPanel(new FlowLayout(FlowLayout.LEFT));
        painelFiltros.setBorder(BorderFactory.createTitledBorder("Filtros"));
        
        painelFiltros.add(new JLabel("Status:"));
        comboFiltroStatus = new JComboBox<>(new String[]{"TODAS", "ABERTA", "EM_ATENDIMENTO", "FECHADA"});
        
        painelFiltros.add(new JLabel("Cliente (ID ou Documento):"));
        txtBuscaCliente = new JTextField(15);
        btnFiltrar = new JButton("Filtrar");
        btnLimparFiltro = new JButton("Limpar Filtros");
        
        btnFiltrar.addActionListener(e -> filtrarOrdens());
        btnLimparFiltro.addActionListener(e -> {
            comboFiltroStatus.setSelectedIndex(0);
            txtBuscaCliente.setText("");
            carregarOrdens();
        });
        
        painelFiltros.add(comboFiltroStatus);
        painelFiltros.add(new JLabel("Cliente:"));
        painelFiltros.add(txtBuscaCliente);
        painelFiltros.add(btnFiltrar);
        painelFiltros.add(btnLimparFiltro);
        
        // Tabela
        String[] colunas = {"ID", "Cliente", "Equipamento", "Nível", "Status", "Motivo", "Data Abertura", "Data Fechamento", "Falha"};
        tableModel = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        tabelaOrdens = new JTable(tableModel);
        tabelaOrdens.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        tabelaOrdens.setRowHeight(25);
        
        // Configurar largura das colunas
        tabelaOrdens.getColumnModel().getColumn(0).setPreferredWidth(50);
        tabelaOrdens.getColumnModel().getColumn(1).setPreferredWidth(200);
        tabelaOrdens.getColumnModel().getColumn(2).setPreferredWidth(150);
        tabelaOrdens.getColumnModel().getColumn(3).setPreferredWidth(80);
        tabelaOrdens.getColumnModel().getColumn(4).setPreferredWidth(100);
        tabelaOrdens.getColumnModel().getColumn(5).setPreferredWidth(250);
        tabelaOrdens.getColumnModel().getColumn(6).setPreferredWidth(130);
        tabelaOrdens.getColumnModel().getColumn(7).setPreferredWidth(130);
        tabelaOrdens.getColumnModel().getColumn(8).setPreferredWidth(100);
        
        JScrollPane scrollTabela = new JScrollPane(tabelaOrdens);
        
        // Painel de bot�es
        JPanel painelBotoes = new JPanel(new FlowLayout());
        
        btnEscalar = new JButton("Escalar para 2� N�vel");
        btnFechar = new JButton("Fechar OS");
        btnAtualizar = new JButton("Atualizar");
        JButton btnVoltar = new JButton("Voltar");
        
        btnEscalar.addActionListener(e -> escalarOrdem());
        btnFechar.addActionListener(e -> fecharOrdem());
        btnAtualizar.addActionListener(e -> carregarOrdens());
        btnVoltar.addActionListener(e -> dispose());
        
        // Habilitar/desabilitar botões baseado na seleção
        tabelaOrdens.getSelectionModel().addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                atualizarBotoes();
            }
        });
        
        painelBotoes.add(btnEscalar);
        painelBotoes.add(btnFechar);
        painelBotoes.add(btnAtualizar);
        painelBotoes.add(btnVoltar);
        
        // Painel de estatísticas
        JPanel painelStats = criarPainelEstatisticas();
        
        add(painelFiltros, BorderLayout.NORTH);
        add(scrollTabela, BorderLayout.CENTER);
        add(painelBotoes, BorderLayout.SOUTH);
        add(painelStats, BorderLayout.EAST);
    }
    
    private JPanel criarPainelEstatisticas() {
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBorder(BorderFactory.createTitledBorder("Estatísticas"));
        panel.setPreferredSize(new Dimension(250, 300));
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.gridwidth = 2;
        
        JLabel lblTotalAbertas = new JLabel();
        JLabel lblTotalFechadas = new JLabel();
        JLabel lblTempoMedio = new JLabel();
        JLabel lblProximaOS = new JLabel();
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("OS Abertas:"), gbc);
        gbc.gridy = 1;
        panel.add(lblTotalAbertas, gbc);
        
        gbc.gridy = 2;
        panel.add(new JLabel("OS Fechadas (90 dias):"), gbc);
        gbc.gridy = 3;
        panel.add(lblTotalFechadas, gbc);
        
        gbc.gridy = 4;
        panel.add(new JLabel("Tempo Médio Resolução:"), gbc);
        gbc.gridy = 5;
        panel.add(lblTempoMedio, gbc);
        
        gbc.gridy = 6;
        panel.add(new JLabel("Próxima OS 1º Nível:"), gbc);
        gbc.gridy = 7;
        panel.add(lblProximaOS, gbc);
        
        // Atualizar estatísticas
        new Timer(5000, e -> {
            List<OrdemServico> abertas = osService.listarOSAbertas();
            lblTotalAbertas.setText(String.valueOf(abertas.size()));
            
            int fechadas = osService.contarOrdensUltimos90Dias();
            lblTotalFechadas.setText(String.valueOf(fechadas));
            
            double tempoMedio = osService.calcularTempoMedioResolucaoUltimos90Dias();
            lblTempoMedio.setText(String.format("%.1f horas", tempoMedio));
            
            OrdemServico proxima = osService.getProximaOSPrimeiroNivel();
            if (proxima != null) {
                lblProximaOS.setText("OS #" + proxima.getId());
            } else {
                lblProximaOS.setText("Nenhuma");
            }
        }).start();
        
        return panel;
    }
    
    private void carregarOrdens() {
        tableModel.setRowCount(0);
        List<OrdemServico> ordens = osService.listarTodasOS();
        adicionarOrdensTabela(ordens);
    }
    
    private void filtrarOrdens() {
        String status = (String) comboFiltroStatus.getSelectedItem();
        String buscaCliente = txtBuscaCliente.getText().trim();
        
        List<OrdemServico> ordens;
        
        if (!"TODAS".equals(status)) {
            ordens = osService.listarOSAbertas();
            if (!"ABERTA".equals(status)) {
                // Para EM_ATENDIMENTO e FECHADA, precisamos filtrar
                ordens = ordens.stream()
                    .filter(os -> os.getStatus().equals(status))
                    .toList();
            } else if ("ABERTA".equals(status)) {
                ordens = osService.listarOSAbertas();
            } else {
                ordens = osService.listarTodasOS();
            }
        } else {
            ordens = osService.listarTodasOS();
        }
        
        if (!buscaCliente.isEmpty()) {
            ordens = ordens.stream()
                .filter(os -> {
                    Cliente c = clienteDAO.buscarPorId(os.getIdCliente());
                    if (c == null) return false;
                    return String.valueOf(os.getIdCliente()).equals(buscaCliente) ||
                           c.getDocumento().contains(buscaCliente);
                })
                .toList();
        }
        
        adicionarOrdensTabela(ordens);
    }
    
    private void adicionarOrdensTabela(List<OrdemServico> ordens) {
        tableModel.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy HH:mm");
        
        for (OrdemServico os : ordens) {
            Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
            String nomeCliente = cliente != null ? cliente.getNomeExibicao() : "N/A";
            
            String nomeEquipamento = "N/A";
            if (os.getIdEquipamento() > 0) {
                var equip = equipamentoDAO.buscarPorId(os.getIdEquipamento());
                if (equip != null) {
                    nomeEquipamento = equip.getMarca() + " " + equip.getModelo();
                }
            }
            
            String statusExibicao = "";
            switch (os.getStatus()) {
                case "ABERTA": statusExibicao = "ABERTA"; break;
                case "EM_ATENDIMENTO": statusExibicao = "EM ATENDIMENTO"; break;
                case "FECHADA": statusExibicao = "FECHADA"; break;
                default: statusExibicao = os.getStatus();
            }
            
            Object[] row = {
                os.getId(),
                nomeCliente,
                nomeEquipamento,
                os.getTipoNivel(),
                statusExibicao,
                os.getMotivo() != null ? (os.getMotivo().length() > 50 ? os.getMotivo().substring(0, 50) + "..." : os.getMotivo()) : "",
                os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                os.getDataFechamento() != null ? sdf.format(os.getDataFechamento()) : "",
                os.getFalhaIdentificada() != null ? os.getFalhaIdentificada() : ""
            };
            tableModel.addRow(row);
        }
    }
    
    private void atualizarBotoes() {
        int row = tabelaOrdens.getSelectedRow();
        boolean selecionado = row >= 0;
        
        if (selecionado) {
            String status = (String) tableModel.getValueAt(row, 4);
            String nivel = (String) tableModel.getValueAt(row, 3);
            
            btnEscalar.setEnabled("ABERTA".equals(status) && "1� N�vel".equals(nivel));
            btnFechar.setEnabled("ABERTA".equals(status));
        } else {
            btnEscalar.setEnabled(false);
            btnFechar.setEnabled(false);
        }
    }
    
    private void escalarOrdem() {
        int row = tabelaOrdens.getSelectedRow();
        if (row < 0) return;
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Deseja escalar esta OS para o 2� N�vel?", 
            "Confirmar Escala��o", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            if (osService.escalarParaSegundoNivel(idOS)) {
                JOptionPane.showMessageDialog(this, "OS escalada para 2º Nível com sucesso!");
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao escalar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void fecharOrdem() {
        int row = tabelaOrdens.getSelectedRow();
        if (row < 0) return;
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        
        JPanel panel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Descri��o da Solu��o:*"), gbc);
        JTextArea txtSolucao = new JTextArea(5, 30);
        txtSolucao.setLineWrap(true);
        JScrollPane scrollSolucao = new JScrollPane(txtSolucao);
        gbc.gridy = 1;
        panel.add(scrollSolucao, gbc);
        
        gbc.gridy = 2;
        panel.add(new JLabel("Falha Identificada:*"), gbc);
        JComboBox<String> combofalha = new JComboBox<>(new String[]{"CLIENTE", "MONITORAMENTO"});
        gbc.gridy = 3;
        panel.add(combofalha, gbc);
        
        int result = JOptionPane.showConfirmDialog(this, panel, 
            "Fechar Ordem de Servi�o", JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (result == JOptionPane.OK_OPTION) {
            String solucao = txtSolucao.getText().trim();
            if (solucao.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Descrição da solução é obrigatória!");
                return;
            }
            
            String falha = (String) combofalha.getSelectedItem();
            
            if (osService.fecharOrdemServico(idOS, solucao, falha, usuarioLogado.getId())) {
                JOptionPane.showMessageDialog(this, "OS fechada com sucesso!");
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao fechar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    @Override
    public void onOSCriada(OrdemServico os) {
        SwingUtilities.invokeLater(() -> {
            carregarOrdens();
            JOptionPane.showMessageDialog(this, 
                "Nova OS #" + os.getId() + " criada para o cliente!\nMotivo: " + os.getMotivo(),
                "Nova Ordem de Servi�o", JOptionPane.INFORMATION_MESSAGE);
        });
    }
    
    @Override
    public void onOSEscalada(OrdemServico os) {
        SwingUtilities.invokeLater(() -> {
            carregarOrdens();
            JOptionPane.showMessageDialog(this, 
                "OS #" + os.getId() + " foi escalada para 2º Nível!",
                "OS Escalada", JOptionPane.INFORMATION_MESSAGE);
        });
    }
    
    @Override
    public void onOSFechada(OrdemServico os) {
        SwingUtilities.invokeLater(() -> {
            carregarOrdens();
        });
    }
}