    private void carregarOrcamentosDoArquivo() {
        try {
            java.io.File file = new java.io.File("data/orcamentos.json");
            java.io.File dir = file.getParentFile();
            if (dir != null && !dir.exists()) {
                dir.mkdirs();
            }
            
            if (file.exists() && file.length() > 0) {
                com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
                mapper.registerModule(new com.fasterxml.jackson.datatype.jsr310.JavaTimeModule());
                mapper.disable(com.fasterxml.jackson.databind.SerializationFeature.WRITE_DATES_AS_TIMESTAMPS);
                
                List<Map<String, Object>> loaded = mapper.readValue(file, 
                    mapper.getTypeFactory().constructCollectionType(List.class, Map.class));
                if (loaded != null && !loaded.isEmpty()) {
                    orcamentos = loaded;
                    for (Map<String, Object> o : orcamentos) {
                        Object idObj = o.get("id");
                        if (idObj instanceof Integer) {
                            int id = (Integer) idObj;
                            if (id >= nextId) {
                                nextId = id + 1;
                            }
                        }
                        
                        if (o.get("data") == null) {
                            o.put("data", new Date());
                        }
                    }
                    System.out.println("Carregados " + orcamentos.size() + " orçamentos do arquivo");
                } else {
                    orcamentos = new ArrayList<>();
                    System.out.println("Arquivo de orçamentos vazio, criando lista nova");
                }
            } else {
                orcamentos = new ArrayList<>();
                salvarOrcamentosNoArquivo();
                System.out.println("Arquivo de orçamentos não existia, criado novo");
            }
        } catch (Exception e) {
            System.err.println("Erro ao carregar orçamentos: " + e.getMessage());
            e.printStackTrace();
            orcamentos = new ArrayList<>();
        }
    }
    
    private void salvarOrcamentosNoArquivo() {
        try {
            java.io.File file = new java.io.File("data/orcamentos.json");
            java.io.File dir = file.getParentFile();
            if (dir != null && !dir.exists()) {
                dir.mkdirs();
            }
            com.fasterxml.jackson.databind.ObjectMapper mapper = new com.fasterxml.jackson.databind.ObjectMapper();
            mapper.registerModule(new com.fasterxml.jackson.datatype.jsr310.JavaTimeModule());
            mapper.enable(com.fasterxml.jackson.databind.SerializationFeature.INDENT_OUTPUT);
            mapper.disable(com.fasterxml.jackson.databind.SerializationFeature.WRITE_DATES_AS_TIMESTAMPS);
            mapper.writeValue(file, orcamentos);
            System.out.println("Salvos " + orcamentos.size() + " orçamentos no arquivo");
        } catch (Exception e) {
            System.err.println("Erro ao salvar orçamentos: " + e.getMessage());
            e.printStackTrace();
        }
    }
    
