        double valorTotal = valorObj instanceof Number ? ((Number) valorObj).doubleValue() : 0;
        String descricao = orcamento.get("descricao") != null ? orcamento.get("descricao").toString() : "";
        
        int idCliente;
        try {
            idCliente = Integer.parseInt(clienteStr.split(" - ")[0]);
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Erro ao identificar cliente!");
            return;
        }
        
        // ================================================================
        // CORREÇÃO PRINCIPAL: Verificar apenas se cliente possui OS aberta
        // NÃO tenta fechar OS de orçamento - orçamento não é OS!
        // ================================================================
        
        // Verificar se o cliente possui alguma OS aberta
        boolean possuiOSAberta = false;
        OrdemServico osExistente = null;
        
        if (osService != null) {
            possuiOSAberta = osService.clientePossuiOSAberta(idCliente);
            if (possuiOSAberta) {
                osExistente = osService.getOSAbertaPorCliente(idCliente);
            }
        } else {
            List<OrdemServico> abertas = ordemServicoDAO.buscarOrdensAbertasPorCliente(idCliente);
            possuiOSAberta = !abertas.isEmpty();
            if (!abertas.isEmpty()) {
                osExistente = abertas.get(0);
            }
        }
        
        // Se existe OS aberta, informar o usuário e cancelar
        if (possuiOSAberta && osExistente != null) {
            String tipoOs = osExistente.getTipoOs() != null ? osExistente.getTipoOs() : "DESCONHECIDA";
            String nivel = osExistente.getTipoNivel() != null ? osExistente.getTipoNivel() : "N/A";
            
            JOptionPane.showMessageDialog(this, 
                "⚠️ ATENÇÃO: O cliente já possui uma OS aberta!\n\n" +
                "Cliente: " + clienteStr + "\n" +
                "OS #" + osExistente.getId() + " - Tipo: " + tipoOs + "\n" +
                "Nível: " + nivel + "\n" +
                "Status: " + osExistente.getStatus() + "\n\n" +
                "Para converter este orçamento em instalação, primeiro feche a OS existente.\n" +
                "Feche a OS #" + osExistente.getId() + " manualmente e tente novamente.",
                "OS Aberta Detectada", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        // Verificar se o cliente possui equipamento
        List<Equipamento> equipamentos = equipamentoDAO.buscarPorCliente(idCliente);
        if (equipamentos.isEmpty()) {
            JOptionPane.showMessageDialog(this, 
                "❌ Cliente não possui equipamento cadastrado!\n\n" +
                "Para criar uma OS de instalação, o cliente precisa ter um equipamento cadastrado.\n" +
                "Cadastre um equipamento primeiro e tente novamente.",
                "Equipamento Necessário", JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        // Solicitar endereço de instalação
        String enderecoInstalacao = JOptionPane.showInputDialog(this, 
            "Informe o endereço de instalação:", 
            "Endereço de Instalação", 
            JOptionPane.QUESTION_MESSAGE);
        
        if (enderecoInstalacao == null || enderecoInstalacao.trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Endereço de instalação é obrigatório!");
            return;
        }
        
        JSpinner spDataAgendamento = new JSpinner(new SpinnerDateModel());
        JSpinner.DateEditor editor = new JSpinner.DateEditor(spDataAgendamento, "dd/MM/yyyy");
        spDataAgendamento.setEditor(editor);
        spDataAgendamento.setValue(new Date());
        
        int resultData = JOptionPane.showConfirmDialog(this, spDataAgendamento, 
            "Selecione a data de agendamento:", 
            JOptionPane.OK_CANCEL_OPTION);
        
        if (resultData != JOptionPane.OK_OPTION) return;
        
        Date dataAgendamento = (Date) spDataAgendamento.getValue();
        
        // ================================================================
        // CRIAÇÃO DA OS DE INSTALAÇÃO (sem fechar nada)
        // ================================================================
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Converter Orçamento #" + idOrcamento + " em Ordem de Instalação\n\n" +
            "Dados do Orçamento:\n" +
            "• Cliente: " + clienteStr + "\n" +
            "• Valor: R$ " + String.format("%.2f", valorTotal) + "\n" +
            "• Descrição: " + (descricao.length() > 100 ? descricao.substring(0, 100) + "..." : descricao) + "\n\n" +
            "A OS de Instalação será criada com:\n" +
            "• Tipo: INSTALAÇÃO\n" +
            "• Departamento Origem: VENDAS\n" +
            "• Endereço: " + enderecoInstalacao + "\n" +
            "• Data Agendamento: " + new SimpleDateFormat("dd/MM/yyyy").format(dataAgendamento) + "\n\n" +
            "Deseja continuar?", 
            "Converter para OS de Instalação", JOptionPane.YES_NO_OPTION);
        
        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }
        
        String motivo = "INSTALAÇÃO - Orçamento #" + idOrcamento + " aprovado - " + descricao;
        String observacoes = "Orçamento #" + idOrcamento + " convertido em instalação.\n" +
                             "Data do orçamento original: " + modelOrcamentos.getValueAt(row, 5) + "\n" +
                             "Valor do orçamento: R$ " + String.format("%.2f", valorTotal);
        
        OrdemServico osInstalacao = null;
        
        // Criar OS de INSTALAÇÃO diretamente (sem usar o service que pode estar com problema)
        osInstalacao = new OrdemServico();
        osInstalacao.setIdCliente(idCliente);
        osInstalacao.setIdEquipamento(equipamentos.isEmpty() ? 0 : equipamentos.get(0).getId());
        osInstalacao.setTipoNivel("1º Nível");
        osInstalacao.setStatus("ABERTA");
        osInstalacao.setMotivo(motivo);
        osInstalacao.setDataAbertura(new Date());
        osInstalacao.setIdUsuarioAbertura(usuarioLogado.getId());
        
        // FORÇAR os tipos corretamente para INSTALAÇÃO
        osInstalacao.setTipoOs("INSTALACAO");
        osInstalacao.setTipoOrdem("INSTALACAO");
        osInstalacao.setDepartamentoOrigem("VENDAS");
        
        osInstalacao.setValorTotal(valorTotal);
        osInstalacao.setEnderecoInstalacao(enderecoInstalacao);
        osInstalacao.setDataAgendamento(dataAgendamento);
        osInstalacao.setDescricaoSolucao(descricao);
        osInstalacao.setObservacoes(observacoes);
        
        System.out.println("=== CRIANDO OS DE INSTALAÇÃO A PARTIR DE ORÇAMENTO ===");
        System.out.println("Cliente ID: " + idCliente);
        System.out.println("TipoOs: " + osInstalacao.getTipoOs());
        System.out.println("TipoOrdem: " + osInstalacao.getTipoOrdem());
        System.out.println("Valor Total: " + valorTotal);
        
        // Inserir a OS diretamente no DAO
        if (ordemServicoDAO.inserir(osInstalacao)) {
            System.out.println("✅ OS de instalação criada com sucesso! ID: " + osInstalacao.getId());
            
            // Adicionar produtos à OS de instalação
            Object produtosObj = orcamento.get("produtos");
            if (produtosObj instanceof List) {
                List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) produtosObj;
                
                for (Map<String, Object> prodMap : produtosOrc) {
                    Object idProdutoObj = prodMap.get("idProduto");
                    Object quantidadeObj = prodMap.get("quantidade");
                    Object precoUnitarioObj = prodMap.get("precoUnitario");
                    
                    if (idProdutoObj != null && quantidadeObj != null) {
                        int idProduto = idProdutoObj instanceof Integer ? (Integer) idProdutoObj : Integer.parseInt(idProdutoObj.toString());
                        int quantidade = quantidadeObj instanceof Integer ? (Integer) quantidadeObj : Integer.parseInt(quantidadeObj.toString());
                        double precoUnitario = precoUnitarioObj instanceof Double ? (Double) precoUnitarioObj : Double.parseDouble(precoUnitarioObj.toString());
                        
                        ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                        if (produto != null) {
                            InstalacaoProduto item = new InstalacaoProduto();
                            item.setIdOrdemInstalacao(osInstalacao.getId());
                            item.setIdProduto(idProduto);
                            item.setNomeProduto(produto.getNome());
                            item.setQuantidade(quantidade);
                            item.setPrecoUnitario(precoUnitario);
                            item.setSubtotal(quantidade * precoUnitario);
                            instalacaoProdutoDAO.inserir(item);
                            
                            // Dar baixa no estoque dos produtos
                            produto.setQuantidade(produto.getQuantidade() - quantidade);
                            produtoDAO.atualizar(produto);
                        }
                    }
                }
            }
            
            // Verificar se a OS foi realmente salva com os tipos corretos
            OrdemServico verificar = ordemServicoDAO.buscarPorId(osInstalacao.getId());
            if (verificar != null) {
                System.out.println("VERIFICAÇÃO PÓS-SALVAMENTO:");
                System.out.println("  - ID: " + verificar.getId());
                System.out.println("  - TipoOs: " + verificar.getTipoOs());
                System.out.println("  - TipoOrdem: " + verificar.getTipoOrdem());
                System.out.println("  - isInstalacao(): " + verificar.isInstalacao());
            }
            
            String mensagemSucesso = "✅ Orçamento #" + idOrcamento + " convertido para Ordem de Instalação #" + osInstalacao.getId() + "!\n\n" +
                "Cliente: " + clienteStr + "\n" +
                "Valor: R$ " + String.format("%.2f", valorTotal) + "\n" +
                "Endereço: " + enderecoInstalacao + "\n" +
                "Data Agendamento: " + new SimpleDateFormat("dd/MM/yyyy").format(dataAgendamento) + "\n" +
                "Data do orçamento original: " + modelOrcamentos.getValueAt(row, 5) + "\n\n" +
                "A OS de Instalação foi aberta com sucesso e aguarda execução.";
            
            JOptionPane.showMessageDialog(this, mensagemSucesso, "Conversão Realizada", JOptionPane.INFORMATION_MESSAGE);
            
            carregarOrcamentos();
        } else {
            System.err.println("❌ FALHA ao inserir OS de instalação!");
            JOptionPane.showMessageDialog(this, 
                "❌ Erro ao criar Ordem de Instalação!\n" +
                "Verifique se o cliente possui um equipamento cadastrado.", 
                "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private class ProdutoOrcamento {
        private ProdutoEstoque produto;
        private int quantidade;
        
        public ProdutoOrcamento(ProdutoEstoque produto, int quantidade) {
            this.produto = produto;
            this.quantidade = quantidade;
        }
        
        public ProdutoEstoque getProduto() { return produto; }
        public int getQuantidade() { return quantidade; }
        public void setQuantidade(int quantidade) { this.quantidade = quantidade; }
    }
}