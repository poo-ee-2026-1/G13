    private void carregarOrcamentos() {
        try {
            modelOrcamentos.setRowCount(0);
            SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy HH:mm");
            
            List<Map<String, Object>> orcamentosOrdenados = orcamentos.stream()
                .sorted((a, b) -> {
                    Object idA = a.get("id");
                    Object idB = b.get("id");
                    int idAint = idA instanceof Integer ? (Integer) idA : Integer.parseInt(idA.toString());
                    int idBint = idB instanceof Integer ? (Integer) idB : Integer.parseInt(idB.toString());
                    return Integer.compare(idBint, idAint);
                })
                .collect(Collectors.toList());
            
            for (Map<String, Object> o : orcamentosOrdenados) {
                int qtdProdutos = 0;
                Object produtosObj = o.get("produtos");
                if (produtosObj instanceof List) {
                    qtdProdutos = ((List<?>) produtosObj).size();
                }
                
                Object idObj = o.get("id");
                Object clienteObj = o.get("cliente");
                Object descricaoObj = o.get("descricao");
                Object valorObj = o.get("valor");
                Object statusObj = o.get("status");
                Object dataObj = o.get("data");
                
                String idStr = idObj != null ? idObj.toString() : "0";
                String clienteStr = clienteObj != null ? clienteObj.toString() : "N/A";
                String descricaoStr = descricaoObj != null ? descricaoObj.toString() : "";
                double valor = 0;
                if (valorObj instanceof Number) {
                    valor = ((Number) valorObj).doubleValue();
                }
                String statusStr = statusObj != null ? statusObj.toString() : "PENDENTE";
                
                String dataStr = "";
                if (dataObj instanceof Date) {
                    dataStr = sdf.format((Date) dataObj);
                } else if (dataObj instanceof Long) {
                    dataStr = sdf.format(new Date((Long) dataObj));
                } else {
                    dataStr = sdf.format(new Date());
                }
                
                Object[] row = {
                    idStr,
                    clienteStr,
                    descricaoStr.length() > 50 ? descricaoStr.substring(0, 50) + "..." : descricaoStr,
                    String.format("%.2f", valor),
                    statusStr,
                    dataStr,
                    qtdProdutos + " itens"
                };
                modelOrcamentos.addRow(row);
            }
            
            btnAprovar.setEnabled(false);
            btnRejeitar.setEnabled(false);
            btnConverterInstalacao.setEnabled(false);
            
        } catch (Exception e) {
            System.err.println("Erro ao carregar orçamentos na tabela: " + e.getMessage());
            e.printStackTrace();
        }
    }
    
