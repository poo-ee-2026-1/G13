    private void aprovarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para aprovar!");
            return;
        }
        
        String idStr = (String) modelOrcamentos.getValueAt(row, 0);
        int id = Integer.parseInt(idStr);
        String status = (String) modelOrcamentos.getValueAt(row, 4);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Apenas orçamentos pendentes podem ser aprovados!");
            return;
        }
        
        Map<String, Object> orcamentoEncontrado = null;
        for (Map<String, Object> o : orcamentos) {
            Object idObj = o.get("id");
            int idOrc = idObj instanceof Integer ? (Integer) idObj : Integer.parseInt(idObj.toString());
            if (idOrc == id) {
                orcamentoEncontrado = o;
                break;
            }
        }
        
        if (orcamentoEncontrado == null) {
            JOptionPane.showMessageDialog(this, "Orçamento não encontrado!");
            return;
        }
        
        Object produtosObj = orcamentoEncontrado.get("produtos");
        if (!(produtosObj instanceof List)) {
            JOptionPane.showMessageDialog(this, "Lista de produtos inválida!");
            return;
        }
        
        List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) produtosObj;
        boolean estoqueOK = true;
        StringBuilder erros = new StringBuilder();
        
        for (Map<String, Object> prodMap : produtosOrc) {
            Object idProdutoObj = prodMap.get("idProduto");
            Object quantidadeObj = prodMap.get("quantidade");
            
            if (idProdutoObj == null || quantidadeObj == null) {
                erros.append("Dados de produto incompletos!\n");
                estoqueOK = false;
                continue;
            }
            
            int idProduto = idProdutoObj instanceof Integer ? (Integer) idProdutoObj : Integer.parseInt(idProdutoObj.toString());
            int quantidade = quantidadeObj instanceof Integer ? (Integer) quantidadeObj : Integer.parseInt(quantidadeObj.toString());
            
            ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
            
            if (produto == null) {
                erros.append("Produto ID ").append(idProduto).append(" não encontrado!\n");
                estoqueOK = false;
            } else if (produto.getQuantidade() < quantidade) {
                erros.append("Estoque insuficiente para: ").append(produto.getNome())
                     .append(" (Disponível: ").append(produto.getQuantidade())
                     .append(", Necessário: ").append(quantidade).append(")\n");
                estoqueOK = false;
            }
        }
        
        if (!estoqueOK) {
            JOptionPane.showMessageDialog(this, 
                "Não foi possível aprovar o orçamento devido a problemas de estoque:\n\n" + erros.toString(),
                "Estoque Insuficiente", JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Aprovar orçamento #" + id + "?\n\n" +
            "Esta ação irá:\n" +
            "1. Dar baixa nos produtos do estoque\n" +
            "2. Registrar a venda\n" +
            "3. O orçamento não poderá mais ser alterado\n\n" +
            "Deseja continuar?",
            "Aprovar Orçamento", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            for (Map<String, Object> prodMap : produtosOrc) {
                Object idProdutoObj = prodMap.get("idProduto");
                Object quantidadeObj = prodMap.get("quantidade");
                Object precoUnitarioObj = prodMap.get("precoUnitario");
                
                int idProduto = idProdutoObj instanceof Integer ? (Integer) idProdutoObj : Integer.parseInt(idProdutoObj.toString());
                int quantidade = quantidadeObj instanceof Integer ? (Integer) quantidadeObj : Integer.parseInt(quantidadeObj.toString());
                double precoUnitario = precoUnitarioObj instanceof Double ? (Double) precoUnitarioObj : Double.parseDouble(precoUnitarioObj.toString());
                
                ProdutoEstoque produto = produtoDAO.buscarPorId(idProduto);
                
                if (produto != null) {
                    produto.setQuantidade(produto.getQuantidade() - quantidade);
                    produtoDAO.atualizar(produto);
                    
                    MovimentacaoEstoque mov = new MovimentacaoEstoque();
                    mov.setIdProduto(idProduto);
                    mov.setTipo("SAIDA");
                    mov.setMotivo("VENDA");
                    mov.setQuantidade(quantidade);
                    mov.setPrecoUnitario(precoUnitario);
                    mov.setValorTotal(quantidade * precoUnitario);
                    mov.setIdUsuario(usuarioLogado.getId());
                    mov.setIdReferencia(id);
                    mov.setObservacao("Orçamento #" + id + " aprovado");
                    movimentacaoDAO.inserir(mov);
                }
            }
            
            for (Map<String, Object> o : orcamentos) {
                Object idObj = o.get("id");
                int idOrc = idObj instanceof Integer ? (Integer) idObj : Integer.parseInt(idObj.toString());
                if (idOrc == id) {
                    o.put("status", "APROVADO");
                    break;
                }
            }
            
            salvarOrcamentosNoArquivo();
            
            JOptionPane.showMessageDialog(this, "Orçamento #" + id + " aprovado com sucesso!\n\n" +
                "Estoque atualizado e venda registrada.\n" +
                "Data do orçamento: " + modelOrcamentos.getValueAt(row, 5));
            carregarOrcamentos();
            
            int converter = JOptionPane.showConfirmDialog(this,
                "Deseja converter este orçamento aprovado em uma Ordem de Instalação?",
                "Converter para Instalação", JOptionPane.YES_NO_OPTION);
            
            if (converter == JOptionPane.YES_OPTION) {
                converterParaInstalacao();
            }
        }
    }
    
    private void rejeitarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para rejeitar!");
            return;
        }
        
        String idStr = (String) modelOrcamentos.getValueAt(row, 0);
        int id = Integer.parseInt(idStr);
        String status = (String) modelOrcamentos.getValueAt(row, 4);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Apenas orçamentos pendentes podem ser rejeitados!");
            return;
        }
        
        String motivo = JOptionPane.showInputDialog(this, "Motivo da rejeição:", "Rejeitar Orçamento", JOptionPane.QUESTION_MESSAGE);
        if (motivo == null) return;
        
        for (Map<String, Object> o : orcamentos) {
            Object idObj = o.get("id");
            int idOrc = idObj instanceof Integer ? (Integer) idObj : Integer.parseInt(idObj.toString());
            if (idOrc == id) {
                Object produtosObj = o.get("produtos");
                if (produtosObj instanceof List) {
                    List<Map<String, Object>> produtosOrc = (List<Map<String, Object>>) produtosObj;
                    for (Map<String, Object> prodMap : produtosOrc) {
                        Object idProdutoObj = prodMap.get("idProduto");
                        Object quantidadeObj = prodMap.get("quantidade");
                        Object precoUnitarioObj = prodMap.get("precoUnitario");
                        
                        if (idProdutoObj != null && quantidadeObj != null) {
                            int idProduto = idProdutoObj instanceof Integer ? (Integer) idProdutoObj : Integer.parseInt(idProdutoObj.toString());
                            int quantidade = quantidadeObj instanceof Integer ? (Integer) quantidadeObj : Integer.parseInt(quantidadeObj.toString());
                            double precoUnitario = precoUnitarioObj instanceof Double ? (Double) precoUnitarioObj : Double.parseDouble(precoUnitarioObj.toString());
                            
                            MovimentacaoEstoque mov = new MovimentacaoEstoque();
                            mov.setIdProduto(idProduto);
                            mov.setTipo("CANCELAMENTO_RESERVA");
                            mov.setMotivo("REJEICAO");
                            mov.setQuantidade(quantidade);
                            mov.setPrecoUnitario(precoUnitario);
                            mov.setValorTotal(quantidade * precoUnitario);
                            mov.setIdUsuario(usuarioLogado.getId());
                            mov.setIdReferencia(id);
                            mov.setObservacao("Orçamento #" + id + " rejeitado - Motivo: " + motivo);
                            movimentacaoDAO.inserir(mov);
                        }
                    }
                }
                
                o.put("status", "REJEITADO");
                o.put("motivoRejeicao", motivo);
                break;
            }
        }
        
        salvarOrcamentosNoArquivo();
        
        JOptionPane.showMessageDialog(this, "Orçamento #" + id + " rejeitado!\nMotivo: " + motivo +
            "\n\nA reserva de produtos foi cancelada.\n" +
            "Data do orçamento: " + modelOrcamentos.getValueAt(row, 5));
        carregarOrcamentos();
    }
    
