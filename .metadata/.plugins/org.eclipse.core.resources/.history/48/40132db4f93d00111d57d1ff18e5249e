package com.monitoramento.ui;

import com.monitoramento.model.Usuario;
import com.monitoramento.model.OrdemServico;
import com.monitoramento.service.MonitoramentoService;
import com.monitoramento.service.OrdemServicoService;
import com.monitoramento.dao.ClienteDAO;
import com.monitoramento.Main;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import javax.swing.table.DefaultTableCellRenderer;
import javax.swing.table.TableColumnModel;
import java.awt.*;
import java.awt.event.*;
import java.util.*;
import java.util.Timer;

public class TelaMonitoramento extends JPanel {
    private JTable tabelaMonitoramento;
    private DefaultTableModel tableModel;
    private JLabel lblStatusConexao;
    private Timer timerAtualizacao;
    private MonitoramentoService monitoramentoService;
    private OrdemServicoService ordemServicoService;
    private Usuario usuarioLogado;
    private boolean pausado = true; // ALTERADO: Iniciar PAUSADO
    private boolean monitoramentoIniciado = false; // NOVO: Controle se o monitoramento já foi iniciado
    
    private int clienteSelecionadoId = -1;
    private boolean restaurandoSelecao = false;
    private boolean atualizandoDados = false;
    
    public TelaMonitoramento(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.monitoramentoService = Main.getMonitoramentoService();
        this.ordemServicoService = Main.getOrdemServicoService();
        
        initComponents();
        iniciarMonitoramento();
        
        // ALTERADO: Inicialmente o monitoramento está pausado
        // Não carregar clientes automaticamente
        // carregarClientesMonitorados(); // REMOVIDO - não carregar inicialmente
        
        // Mostrar mensagem informativa
        JOptionPane.showMessageDialog(this, 
            "⚠️ Monitoramento INICIADO EM MODO PAUSA!\n\n" +
            "Para começar a monitorar os clientes:\n" +
            "1. Certifique-se que há clientes marcados para monitoramento\n" +
            "2. Clique no botão '▶ Retomar (F8)' no painel de controle\n\n" +
            "Enquanto pausado, a tela NÃO será atualizada automaticamente\n" +
            "e NENHUMA OS automática será aberta.", 
            "Monitoramento Pausado", JOptionPane.INFORMATION_MESSAGE);
    }
    
