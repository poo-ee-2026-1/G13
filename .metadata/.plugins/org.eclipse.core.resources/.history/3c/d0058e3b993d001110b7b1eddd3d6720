    private class EstadoRedeRenderer extends DefaultTableCellRenderer {
        public EstadoRedeRenderer() {
            setHorizontalAlignment(SwingConstants.CENTER);
        }
        
        @Override
        public Component getTableCellRendererComponent(JTable table, Object value,
                boolean isSelected, boolean hasFocus, int row, int column) {
            Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);
            
            Font currentFont = c.getFont();
            c.setFont(new Font(currentFont.getName(), Font.BOLD, currentFont.getSize()));
            
            if (value != null) {
                String estado = value.toString();
                
                if ("ATIVO".equals(estado)) {
                    c.setForeground(new Color(0, 150, 0));
                } else if ("INATIVO".equals(estado)) {
                    c.setForeground(Color.RED);
                } else if ("SEM COMUNICAÇÃO".equals(estado)) {
                    c.setForeground(Color.RED);
                } else {
                    c.setForeground(Color.BLACK);
                }
            }
            
            if (isSelected) {
                c.setBackground(table.getSelectionBackground());
            } else {
                c.setBackground(table.getBackground());
            }
            
            return c;
        }
    }
    
    private class TensaoRenderer extends DefaultTableCellRenderer {
        public TensaoRenderer() {
            setHorizontalAlignment(SwingConstants.CENTER);
        }
        
        @Override
        public Component getTableCellRendererComponent(JTable table, Object value,
                boolean isSelected, boolean hasFocus, int row, int column) {
            Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);
            
            Font currentFont = c.getFont();
            c.setFont(new Font(currentFont.getName(), Font.BOLD, currentFont.getSize()));
            
            if (value != null && !"---".equals(value.toString())) {
                try {
                    double tensao = Double.parseDouble(value.toString().replace(",", "."));
                    if (tensao == 0) {
                        c.setForeground(Color.RED);
                    } else if (tensao < 100) {
                        c.setForeground(new Color(255, 100, 0));
                    } else {
                        c.setForeground(new Color(0, 0, 180));
                    }
                } catch (NumberFormatException e) {
                    c.setForeground(Color.GRAY);
                }
            } else if (value != null && "---".equals(value.toString())) {
                c.setForeground(Color.GRAY);
            }
            
            if (isSelected) {
                c.setBackground(table.getSelectionBackground());
            } else {
                c.setBackground(table.getBackground());
            }
            
            return c;
        }
    }
    
    private class SituacaoRedeRenderer extends DefaultTableCellRenderer {
        public SituacaoRedeRenderer() {
            setHorizontalAlignment(SwingConstants.CENTER);
        }
        
        @Override
        public Component getTableCellRendererComponent(JTable table, Object value,
                boolean isSelected, boolean hasFocus, int row, int column) {
            Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);
            
            Font currentFont = c.getFont();
            c.setFont(new Font(currentFont.getName(), Font.BOLD, currentFont.getSize()));
            
            if (value != null) {
                String situacao = value.toString();
                
                if (situacao.contains("NORMAL")) {
                    c.setForeground(new Color(0, 150, 0));
                } else if (situacao.contains("ALERTA")) {
                    c.setForeground(new Color(255, 140, 0));
                } else if (situacao.contains("CRÍTICO")) {
                    c.setForeground(Color.RED);
                } else {
                    c.setForeground(Color.BLACK);
                }
            }
            
            if (isSelected) {
                c.setBackground(table.getSelectionBackground());
            } else {
                c.setBackground(table.getBackground());
            }
            
            return c;
        }
    }
    
    private class DisponibilidadeRenderer extends DefaultTableCellRenderer {
        public DisponibilidadeRenderer() {
            setHorizontalAlignment(SwingConstants.CENTER);
        }
        
        @Override
        public Component getTableCellRendererComponent(JTable table, Object value,
                boolean isSelected, boolean hasFocus, int row, int column) {
            Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);
            
            Font currentFont = c.getFont();
            c.setFont(new Font(currentFont.getName(), Font.BOLD, currentFont.getSize()));
            
            if (value != null && !"---".equals(value.toString())) {
                String dispStr = value.toString().replace("%", "");
                try {
                    double disponibilidade = Double.parseDouble(dispStr);
                    if (disponibilidade >= 95) {
                        c.setForeground(new Color(0, 150, 0));
                    } else if (disponibilidade >= 70) {
                        c.setForeground(new Color(255, 140, 0));
                    } else {
                        c.setForeground(Color.RED);
                    }
                } catch (NumberFormatException e) {
                    c.setForeground(Color.GRAY);
                }
            } else if (value != null && "---".equals(value.toString())) {
                c.setForeground(Color.GRAY);
            }
            
            if (isSelected) {
                c.setBackground(table.getSelectionBackground());
            } else {
                c.setBackground(table.getBackground());
            }
            
            return c;
        }
    }
