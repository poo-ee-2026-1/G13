    public TelaTI(Usuario usuario) {
        this.usuarioLogado = usuario;
        this.ordemServicoDAO = new OrdemServicoDAO();
        this.clienteDAO = new ClienteDAO();
        this.equipamentoDAO = new EquipamentoDAO();
        
        try {
            this.osService = Main.getOrdemServicoService();
            if (this.osService == null) {
                System.err.println("OrdemServicoService não disponível, usando DAO diretamente");
            }
        } catch (Exception e) {
            System.err.println("Erro ao obter OrdemServicoService: " + e.getMessage());
            this.osService = null;
        }
        
        if (!usuario.getFuncao().equals("Técnico") && 
            !usuario.getFuncao().equals("Administrador") && 
            !usuario.getFuncao().equals("Gerente")) {
            JOptionPane.showMessageDialog(this, "Apenas Técnicos, Gerentes ou Administradores podem acessar o TI!");
            return;
        }
        
        initComponents();
        carregarOrdens();
        
        timerAtualizacao = new Timer(5000, e -> carregarOrdens());
        timerAtualizacao.start();
    }
    
