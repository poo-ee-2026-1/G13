    private String getTipoExibicao(String tipo) {
        return TIPO_EXIBICAO.getOrDefault(tipo, tipo);
    }
    
    private String determinarTipoOs(OrdemServico os) {
        if (os.getTipoOs() != null) {
            return getTipoExibicao(os.getTipoOs());
        }
        if (os.isInstalacao()) return "INSTALAÇÃO";
        if (os.isOrcamento()) return "ORÇAMENTO";
        if (os.isInformacao()) return "INFORMAÇÃO";
        if (os.isReparo()) return "REPARO";
        return "SERVIÇO";
    }
    
    private String formatarStatus(String status) {
        if (status == null) return "---";
        switch (status) {
            case "ABERTA": return "ABERTA";
            case "EM_ATENDIMENTO": return "EM ATENDIMENTO";
            case "FECHADA": return "FECHADA";
            default: return status;
        }
    }
    
    private void carregarOrdens() {
        tableModel.setRowCount(0);
        List<OrdemServico> ordens;
        
        if (osService != null) {
            ordens = osService.listarTodasOS();
        } else {
            ordens = ordemServicoDAO.listarTodas();
        }
        
        adicionarOrdensTabela(ordens);
        lblStatusInfo.setText("Sistema de OS - TI (REPARO) | Total de OS: " + ordens.size() + " | Usuário: " + usuarioLogado.getNomeCompleto());
    }
    
    private void filtrarOrdens() {
        String status = (String) comboFiltroStatus.getSelectedItem();
        String nivel = (String) comboFiltroNivel.getSelectedItem();
        String tipoOsFiltro = (String) comboTipoOsFiltro.getSelectedItem();
        String buscaCliente = txtBuscaCliente.getText().trim();
        
        List<OrdemServico> ordens;
        
        if (osService != null) {
            ordens = osService.listarTodasOS();
        } else {
            ordens = ordemServicoDAO.listarTodas();
        }
        
        // Filtro por Status
        if (!"TODAS".equals(status)) {
            ordens = ordens.stream()
                .filter(os -> os.getStatus() != null && os.getStatus().equals(status))
                .toList();
        }
        
        // Filtro por Nível
        if (!"TODOS".equals(nivel)) {
            ordens = ordens.stream()
                .filter(os -> os.getTipoNivel() != null && os.getTipoNivel().equals(nivel))
                .toList();
        }
        
        // Filtro por Tipo de OS
        if (!"TODOS".equals(tipoOsFiltro)) {
            ordens = ordens.stream()
                .filter(os -> {
                    String tipo = os.getTipoOs();
                    if (tipo == null) return false;
                    return tipo.equals(tipoOsFiltro);
                })
                .toList();
        }
        
        // Filtro por Cliente
        if (!buscaCliente.isEmpty()) {
            ordens = ordens.stream()
                .filter(os -> {
                    Cliente c = clienteDAO.buscarPorId(os.getIdCliente());
                    if (c == null) return false;
                    return String.valueOf(os.getIdCliente()).equals(buscaCliente) ||
                           c.getDocumento().contains(buscaCliente);
                })
                .toList();
        }
        
        adicionarOrdensTabela(ordens);
    }
    
    private void adicionarOrdensTabela(List<OrdemServico> ordens) {
        tableModel.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy HH:mm");
        
        for (OrdemServico os : ordens) {
            Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
            String nomeCliente = cliente != null ? cliente.getNomeExibicao() : "N/A";
            
            String tipoOs = determinarTipoOs(os);
            String statusExibicao = formatarStatus(os.getStatus());
            
            Object[] row = {
                os.getId(),
                nomeCliente,
                tipoOs,
                os.getTipoNivel(),
                statusExibicao,
                os.getMotivo() != null ? (os.getMotivo().length() > 60 ? os.getMotivo().substring(0, 60) + "..." : os.getMotivo()) : "",
                os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                os.getDataFechamento() != null ? sdf.format(os.getDataFechamento()) : ""
            };
            tableModel.addRow(row);
        }
        
        if (tableModel.getRowCount() == 0) {
            Object[] row = {"---", "Nenhum registro encontrado", "---", "---", "---", "---", "---", "---"};
            tableModel.addRow(row);
        }
    }
    
    private void atualizarBotoes() {
        int row = tabelaOS.getSelectedRow();
        boolean selecionado = row >= 0;
        
        if (selecionado) {
            String status = (String) tableModel.getValueAt(row, 4);
            String nivel = (String) tableModel.getValueAt(row, 3);
            
            btnAbrirOS.setEnabled(true);
            btnEscalar.setEnabled(!"FECHADA".equals(status));
            btnFecharOS.setEnabled(!"FECHADA".equals(status));
            
            if ("1º Nível".equals(nivel)) {
                btnEscalar.setToolTipText("Escalar para 2º Nível");
            } else if ("2º Nível".equals(nivel)) {
                btnEscalar.setToolTipText("Escalar para 3º Nível");
            } else if ("3º Nível".equals(nivel)) {
                btnEscalar.setToolTipText("Já está no nível máximo");
            }
        } else {
            btnAbrirOS.setEnabled(true);
            btnEscalar.setEnabled(false);
            btnFecharOS.setEnabled(false);
            btnEscalar.setToolTipText("Selecione uma OS primeiro");
        }
    }
    
    private void abrirOSManual() {
        List<Cliente> todosClientes = clienteDAO.listarTodos();
        List<OrdemServico> ordensAbertas;
        
        if (osService != null) {
            ordensAbertas = osService.listarOSAbertas();
        } else {
            ordensAbertas = ordemServicoDAO.buscarPorStatus("ABERTA");
        }
        
        List<Cliente> clientesDisponiveis = todosClientes.stream()
            .filter(c -> ordensAbertas.stream().noneMatch(os -> os.getIdCliente() == c.getId()))
            .toList();
        
        if (clientesDisponiveis.isEmpty()) {
            JOptionPane.showMessageDialog(this, 
                "⚠️ Todos os clientes já possuem uma OS aberta!\n" +
                "Feche as OS existentes antes de abrir novas.", 
                "Aviso", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        JDialog dialog = new JDialog(SwingUtilities.getWindowAncestor(this), "Abrir Ordem de Serviço - TI (REPARO)", Dialog.ModalityType.APPLICATION_MODAL);
        dialog.setSize(550, 480);
        dialog.setLocationRelativeTo(this);
        dialog.setLayout(new BorderLayout());
        
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(8, 8, 8, 8);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Cliente:*"), gbc);
        
        JComboBox<String> comboCliente = new JComboBox<>();
        for (Cliente c : clientesDisponiveis) {
            comboCliente.addItem(c.getId() + " - " + c.getNomeExibicao());
        }
        gbc.gridx = 1; gbc.gridwidth = 2;
        panel.add(comboCliente, gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        gbc.gridwidth = 1;
        panel.add(new JLabel("Motivo (REPARO):*"), gbc);
        
        JTextArea txtMotivo = new JTextArea(5, 35);
        txtMotivo.setLineWrap(true);
        txtMotivo.setWrapStyleWord(true);
        JScrollPane scrollMotivo = new JScrollPane(txtMotivo);
        gbc.gridx = 1; gbc.gridy = 1; gbc.gridwidth = 2;
        panel.add(scrollMotivo, gbc);
        
        JLabel lblInfo = new JLabel("Esta OS será do tipo REPARO e pode ser escalada até 3º Nível", SwingConstants.CENTER);
        lblInfo.setFont(new Font("Arial", Font.ITALIC, 11));
        lblInfo.setForeground(Color.BLUE);
        gbc.gridy = 2;
        panel.add(lblInfo, gbc);
        
        JPanel botoesPanel = new JPanel(new FlowLayout());
        JButton btnConfirmar = new JButton("Abrir OS (REPARO)");
        JButton btnCancelar = new JButton("Cancelar");
        
        btnConfirmar.setBackground(new Color(60, 120, 60));
        btnConfirmar.setForeground(Color.WHITE);
        btnConfirmar.setFont(new Font("Arial", Font.BOLD, 12));
        
        btnConfirmar.addActionListener(e -> {
            if (comboCliente.getSelectedIndex() == -1) {
                JOptionPane.showMessageDialog(dialog, "Selecione um cliente!");
                return;
            }
            
            String motivo = txtMotivo.getText().trim();
            if (motivo.isEmpty()) {
                JOptionPane.showMessageDialog(dialog, "Informe o motivo da OS!");
                return;
            }
            
            String selected = (String) comboCliente.getSelectedItem();
            int idCliente = Integer.parseInt(selected.split(" - ")[0]);
            
            OrdemServico os;
            if (osService != null) {
                os = osService.abrirOSTI(idCliente, motivo, usuarioLogado.getId());
            } else {
                List<Equipamento> equipamentos = equipamentoDAO.buscarPorCliente(idCliente);
                os = new OrdemServico();
                os.setIdCliente(idCliente);
                os.setIdEquipamento(equipamentos.isEmpty() ? 0 : equipamentos.get(0).getId());
                os.setTipoNivel("1º Nível");
                os.setStatus("ABERTA");
                os.setMotivo(motivo);
                os.setDataAbertura(new Date());
                os.setIdUsuarioAbertura(usuarioLogado.getId());
                os.setTipoOs("REPARO");
                os.setDepartamentoOrigem("TI");
                os.setTipoOrdem("SERVICO");
                ordemServicoDAO.inserir(os);
            }
            
            if (os != null && os.getId() > 0) {
                JOptionPane.showMessageDialog(dialog, 
                    "✅ OS #" + os.getId() + " (REPARO) aberta com sucesso!\n\n" +
                    "Cliente: " + selected.split(" - ")[1] + "\n" +
                    "Motivo: " + motivo);
                dialog.dispose();
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(dialog, 
                    "❌ Erro ao abrir OS!\nVerifique se o cliente já não possui uma OS aberta.", 
                    "Erro", JOptionPane.ERROR_MESSAGE);
            }
        });
        
        btnCancelar.addActionListener(e -> dialog.dispose());
        
        botoesPanel.add(btnConfirmar);
        botoesPanel.add(btnCancelar);
        
        dialog.add(panel, BorderLayout.CENTER);
        dialog.add(botoesPanel, BorderLayout.SOUTH);
        dialog.setVisible(true);
    }
    
    private void escalarOrdem() {
        int row = tabelaOS.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione uma OS para escalar!");
            return;
        }
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        String nivelAtual = (String) tableModel.getValueAt(row, 3);
        String status = (String) tableModel.getValueAt(row, 4);
        
        if ("FECHADA".equals(status)) {
            JOptionPane.showMessageDialog(this, "Não é possível escalar uma OS já fechada!");
            return;
        }
        
        String proximoNivel = null;
        if ("1º Nível".equals(nivelAtual)) {
            proximoNivel = "2º Nível";
        } else if ("2º Nível".equals(nivelAtual)) {
            proximoNivel = "3º Nível";
        } else if ("3º Nível".equals(nivelAtual)) {
            JOptionPane.showMessageDialog(this, "⚠️ Esta OS já está no nível máximo (3º Nível)!\nNão é possível escalar além deste nível.", 
                "Aviso", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "📋 Escalar OS #" + idOS + "\n" +
            "Nível atual: " + nivelAtual + "\n" +
            "Novo nível: " + proximoNivel + "\n\n" +
            "Deseja continuar?", 
            "Confirmar Escalação", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            boolean sucesso;
            
            if (osService != null) {
                if ("2º Nível".equals(proximoNivel)) {
                    sucesso = osService.escalarParaSegundoNivel(idOS);
                } else {
                    sucesso = osService.escalarParaTerceiroNivel(idOS);
                }
            } else {
                OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
                if (os != null) {
                    os.setTipoNivel(proximoNivel);
                    sucesso = ordemServicoDAO.atualizar(os);
                } else {
                    sucesso = false;
                }
            }
            
            if (sucesso) {
                JOptionPane.showMessageDialog(this, 
                    "✅ OS #" + idOS + " escalada com sucesso!\n" +
                    "Novo nível: " + proximoNivel);
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "❌ Erro ao escalar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void fecharOrdem() {
        int row = tabelaOS.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione uma OS para fechar!");
            return;
        }
        
        int idOS = (int) tableModel.getValueAt(row, 0);
        String status = (String) tableModel.getValueAt(row, 4);
        
        if ("FECHADA".equals(status)) {
            JOptionPane.showMessageDialog(this, "Esta OS já está fechada!");
            return;
        }
        
        JPanel panel = new JPanel(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(5, 5, 5, 5);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        gbc.gridx = 0; gbc.gridy = 0;
        panel.add(new JLabel("Descrição da Solução:*"), gbc);
        JTextArea txtSolucao = new JTextArea(5, 35);
        txtSolucao.setLineWrap(true);
        txtSolucao.setWrapStyleWord(true);
        JScrollPane scrollSolucao = new JScrollPane(txtSolucao);
        gbc.gridy = 1;
        panel.add(scrollSolucao, gbc);
        
        gbc.gridy = 2;
        panel.add(new JLabel("Falha Identificada:*"), gbc);
        JComboBox<String> comboFalha = new JComboBox<>(new String[]{
            "CLIENTE", "MONITORAMENTO", "INSTALAÇÃO", "HARDWARE", "SOFTWARE", "REDE", "ENERGIA", "OUTRO"
        });
        gbc.gridy = 3;
        panel.add(comboFalha, gbc);
        
        gbc.gridy = 4;
        panel.add(new JLabel("Nível de dificuldade:"), gbc);
        JComboBox<String> comboDificuldade = new JComboBox<>(new String[]{"BAIXA", "MÉDIA", "ALTA", "CRÍTICA"});
        gbc.gridy = 5;
        panel.add(comboDificuldade, gbc);
        
        int result = JOptionPane.showConfirmDialog(this, panel, 
            "Fechar Ordem de Serviço #" + idOS, 
            JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
        
        if (result == JOptionPane.OK_OPTION) {
            String solucao = txtSolucao.getText().trim();
            if (solucao.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Descrição da solução é obrigatória!");
                return;
            }
            
            String falha = (String) comboFalha.getSelectedItem();
            String dificuldade = (String) comboDificuldade.getSelectedItem();
            
            String solucaoCompleta = "[Nível " + dificuldade + "] " + solucao + 
                "\n\nDificuldade: " + dificuldade;
            
            boolean sucesso;
            if (osService != null) {
                sucesso = osService.fecharOrdemServico(idOS, solucaoCompleta, falha, usuarioLogado.getId());
            } else {
                sucesso = ordemServicoDAO.fecharOrdemServico(idOS, solucaoCompleta, falha, usuarioLogado.getId());
            }
            
            if (sucesso) {
                JOptionPane.showMessageDialog(this, 
                    "✅ OS #" + idOS + " fechada com sucesso!\n\n" +
                    "Falha: " + falha + "\n" +
                    "Dificuldade: " + dificuldade);
                carregarOrdens();
            } else {
                JOptionPane.showMessageDialog(this, "❌ Erro ao fechar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    @Override
    public void removeNotify() {
        super.removeNotify();
        if (timerAtualizacao != null) {
            timerAtualizacao.stop();
        }
    }
