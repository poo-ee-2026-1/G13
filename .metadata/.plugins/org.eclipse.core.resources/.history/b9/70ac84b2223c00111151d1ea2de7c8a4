    public double calcularTempoMedioResolucao(Date dataInicio, Date dataFim) {
        String sql = "SELECT AVG(TIMESTAMPDIFF(HOUR, data_abertura, data_fechamento)) as media_horas " +
                     "FROM ordens_servico WHERE status = 'FECHADA' AND data_fechamento BETWEEN ? AND ?";
        
        try (Connection conn = DatabaseConnection.getConnection();
             PreparedStatement stmt = conn.prepareStatement(sql)) {
            
            stmt.setTimestamp(1, new Timestamp(dataInicio.getTime()));
            stmt.setTimestamp(2, new Timestamp(dataFim.getTime()));
            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    return rs.getDouble("media_horas");
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return 0;
    }
    
    private OrdemServico mapearOrdemServico(ResultSet rs) throws SQLException {
        OrdemServico os = new OrdemServico();
        os.setId(rs.getInt("id"));
        os.setIdCliente(rs.getInt("id_cliente"));
        os.setIdEquipamento(rs.getInt("id_equipamento"));
        os.setTipoNivel(rs.getString("tipo_nivel"));
        os.setStatus(rs.getString("status"));
        os.setMotivo(rs.getString("motivo"));
        os.setDescricaoSolucao(rs.getString("descricao_solucao"));
        os.setFalhaIdentificada(rs.getString("falha_identificada"));
        
        Timestamp tsAbertura = rs.getTimestamp("data_abertura");
        if (tsAbertura != null) {
            os.setDataAbertura(new Date(tsAbertura.getTime()));
        }
        
        Timestamp tsFechamento = rs.getTimestamp("data_fechamento");
        if (tsFechamento != null) {
            os.setDataFechamento(new Date(tsFechamento.getTime()));
        }
        
        os.setIdUsuarioAbertura(rs.getInt("id_usuario_abertura"));
        
        int idUsuarioFechamento = rs.getInt("id_usuario_fechamento