// ========== PAINEL PARA ORDENS DE SERVIÇO (ST) - ATUALIZADO ==========
private JPanel criarPainelOrdensST() {
    JPanel panel = new JPanel(new BorderLayout());
    panel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
    
    // Painel de filtros
    JPanel painelFiltros = new JPanel(new FlowLayout(FlowLayout.LEFT));
    painelFiltros.setBorder(BorderFactory.createTitledBorder("Filtros"));
    
    painelFiltros.add(new JLabel("Status:"));
    comboFiltroStatusST = new JComboBox<>(new String[]{"TODAS", "ABERTA", "EM_ATENDIMENTO", "FECHADA"});
    
    painelFiltros.add(new JLabel("Nível:"));
    comboFiltroNivelST = new JComboBox<>(new String[]{"TODOS", "1º Nível", "2º Nível", "3º Nível"});
    
    JButton btnFiltrarST = new JButton("Filtrar");
    JButton btnLimparST = new JButton("Limpar");
    
    btnFiltrarST.addActionListener(e -> filtrarOrdensST());
    btnLimparST.addActionListener(e -> {
        comboFiltroStatusST.setSelectedIndex(0);
        comboFiltroNivelST.setSelectedIndex(0);
        carregarOrdensST();
    });
    
    painelFiltros.add(comboFiltroStatusST);
    painelFiltros.add(comboFiltroNivelST);
    painelFiltros.add(btnFiltrarST);
    painelFiltros.add(btnLimparST);
    
    // Tabela de Ordens de Serviço
    String[] colunas = {"ID", "Cliente", "Equipamento", "Nível", "Status", "Motivo", "Data Abertura", "Data Fechamento"};
    modelOrdensST = new DefaultTableModel(colunas, 0) {
        @Override
        public boolean isCellEditable(int row, int column) {
            return false;
        }
    };
    
    tabelaOrdensST = new JTable(modelOrdensST);
    tabelaOrdensST.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
    tabelaOrdensST.setRowHeight(25);
    
    tabelaOrdensST.getColumnModel().getColumn(0).setPreferredWidth(50);
    tabelaOrdensST.getColumnModel().getColumn(1).setPreferredWidth(200);
    tabelaOrdensST.getColumnModel().getColumn(2).setPreferredWidth(150);
    tabelaOrdensST.getColumnModel().getColumn(3).setPreferredWidth(80);
    tabelaOrdensST.getColumnModel().getColumn(4).setPreferredWidth(100);
    tabelaOrdensST.getColumnModel().getColumn(5).setPreferredWidth(300);
    tabelaOrdensST.getColumnModel().getColumn(6).setPreferredWidth(130);
    tabelaOrdensST.getColumnModel().getColumn(7).setPreferredWidth(130);
    
    JScrollPane scrollTabela = new JScrollPane(tabelaOrdensST);
    
    // ========== PAINEL DE BOTÕES (MESMO FORMATO DA TELA TI) ==========
    JPanel painelBotoes = new JPanel(new FlowLayout());
    
    btnAbrirOS = new JButton("Abrir OS");
    btnEscalarOS = new JButton("Escalar para 2º Nível");
    btnFecharOS = new JButton("Fechar OS");
    btnAtualizarOS = new JButton("Atualizar");
    
    // Estilizando botões para manter consistência
    btnAbrirOS.setBackground(new Color(60, 120, 60));
    btnAbrirOS.setForeground(Color.WHITE);
    btnEscalarOS.setBackground(new Color(200, 120, 0));
    btnEscalarOS.setForeground(Color.WHITE);
    btnFecharOS.setBackground(new Color(180, 60, 60));
    btnFecharOS.setForeground(Color.WHITE);
    btnAtualizarOS.setBackground(new Color(100, 100, 100));
    btnAtualizarOS.setForeground(Color.WHITE);
    
    btnAbrirOS.addActionListener(e -> abrirOSManualST());
    btnEscalarOS.addActionListener(e -> escalarOrdemST());
    btnFecharOS.addActionListener(e -> fecharOrdemST());
    btnAtualizarOS.addActionListener(e -> carregarOrdensST());
    
    tabelaOrdensST.getSelectionModel().addListSelectionListener(e -> {
        if (!e.getValueIsAdjusting()) {
            atualizarBotoesST();
        }
    });
    
    painelBotoes.add(btnAbrirOS);
    painelBotoes.add(btnEscalarOS);
    painelBotoes.add(btnFecharOS);
    painelBotoes.add(btnAtualizarOS);
    
    // Painel de instruções
    JPanel painelInstrucoes = new JPanel();
    painelInstrucoes.setBackground(new Color(240, 248, 255));
    JLabel lblInstrucoes = new JLabel("Instruções: Selecione uma OS para gerenciar. Use 'Abrir OS' para nova ordem, 'Escalar' para próximo nível, 'Fechar OS' para concluir.");
    lblInstrucoes.setFont(new Font("Arial", Font.PLAIN, 12));
    painelInstrucoes.add(lblInstrucoes);
    
    panel.add(painelFiltros, BorderLayout.NORTH);
    panel.add(scrollTabela, BorderLayout.CENTER);
    panel.add(painelBotoes, BorderLayout.SOUTH);
    panel.add(painelInstrucoes, BorderLayout.PAGE_END);
    
    return panel;
}

// ========== MÉTODO ABRIR OS (ST) - ATUALIZADO ==========
private void abrirOSManualST() {
    List<Cliente> todosClientes = clienteDAO.listarTodos();
    List<OrdemServico> ordensAbertas = ordemServicoDAO.buscarPorStatus("ABERTA");
    
    // Filtra clientes que não possuem OS aberta
    List<Cliente> clientesDisponiveis = todosClientes.stream()
        .filter(c -> ordensAbertas.stream().noneMatch(os -> os.getIdCliente() == c.getId()))
        .toList();
    
    if (clientesDisponiveis.isEmpty()) {
        JOptionPane.showMessageDialog(this, 
            "Todos os clientes já possuem uma OS aberta!\n" +
            "Feche as OS existentes antes de abrir novas.", 
            "Aviso", JOptionPane.WARNING_MESSAGE);
        return;
    }
    
    JDialog dialog = new JDialog(SwingUtilities.getWindowAncestor(this), "Abrir Ordem de Serviço - ST", Dialog.ModalityType.APPLICATION_MODAL);
    dialog.setSize(500, 450);
    dialog.setLocationRelativeTo(this);
    dialog.setLayout(new BorderLayout());
    
    JPanel panel = new JPanel(new GridBagLayout());
    panel.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));
    GridBagConstraints gbc = new GridBagConstraints();
    gbc.insets = new Insets(8, 8, 8, 8);
    gbc.fill = GridBagConstraints.HORIZONTAL;
    
    gbc.gridx = 0; gbc.gridy = 0;
    panel.add(new JLabel("Cliente:*"), gbc);
    
    JComboBox<String> comboCliente = new JComboBox<>();
    for (Cliente c : clientesDisponiveis) {
        comboCliente.addItem(c.getId() + " - " + c.getNomeExibicao());
    }
    gbc.gridx = 1; gbc.gridwidth = 2;
    panel.add(comboCliente, gbc);
    
    gbc.gridx = 0; gbc.gridy = 1;
    gbc.gridwidth = 1;
    panel.add(new JLabel("Nível da OS:*"), gbc);
    
    JComboBox<String> comboNivel = new JComboBox<>(new String[]{"1º Nível", "2º Nível", "3º Nível"});
    gbc.gridx = 1; gbc.gridwidth = 2;
    panel.add(comboNivel, gbc);
    
    gbc.gridx = 0; gbc.gridy = 2;
    gbc.gridwidth = 1;
    panel.add(new JLabel("Motivo:*"), gbc);
    
    JTextArea txtMotivo = new JTextArea(5, 30);
    txtMotivo.setLineWrap(true);
    txtMotivo.setWrapStyleWord(true);
    JScrollPane scrollMotivo = new JScrollPane(txtMotivo);
    gbc.gridx = 1; gbc.gridy = 2; gbc.gridwidth = 2;
    panel.add(scrollMotivo, gbc);
    
    JPanel botoesPanel = new JPanel(new FlowLayout());
    JButton btnConfirmar = new JButton("Abrir OS");
    JButton btnCancelar = new JButton("Cancelar");
    
    btnConfirmar.addActionListener(e -> {
        if (comboCliente.getSelectedIndex() == -1) {
            JOptionPane.showMessageDialog(dialog, "Selecione um cliente!");
            return;
        }
        
        String motivo = txtMotivo.getText().trim();
        if (motivo.isEmpty()) {
            JOptionPane.showMessageDialog(dialog, "Informe o motivo da OS!");
            return;
        }
        
        String selected = (String) comboCliente.getSelectedItem();
        int idCliente = Integer.parseInt(selected.split(" - ")[0]);
        String nivel = (String) comboNivel.getSelectedItem();
        
        // Buscar equipamento do cliente
        List<Equipamento> equipamentos = equipamentoDAO.buscarPorCliente(idCliente);
        int idEquipamento = equipamentos.isEmpty() ? 0 : equipamentos.get(0).getId();
        
        OrdemServico os = new OrdemServico();
        os.setIdCliente(idCliente);
        os.setIdEquipamento(idEquipamento);
        os.setTipoNivel(nivel);
        os.setStatus("ABERTA");
        os.setMotivo(motivo);
        os.setDataAbertura(new Date());
        os.setIdUsuarioAbertura(usuarioLogado.getId());
        os.setTipoOrdem("SERVICO");
        
        if (ordemServicoDAO.inserir(os)) {
            JOptionPane.showMessageDialog(dialog, 
                "OS #" + os.getId() + " aberta com sucesso!\n" +
                "Cliente: " + selected.split(" - ")[1] + "\n" +
                "Nível: " + nivel + "\n" +
                "Motivo: " + motivo);
            dialog.dispose();
            carregarOrdensST();
        } else {
            JOptionPane.showMessageDialog(dialog, 
                "Erro ao abrir OS!\nVerifique se o cliente já não possui uma OS aberta.", 
                "Erro", JOptionPane.ERROR_MESSAGE);
        }
    });
    
    btnCancelar.addActionListener(e -> dialog.dispose());
    
    botoesPanel.add(btnConfirmar);
    botoesPanel.add(btnCancelar);
    
    dialog.add(panel, BorderLayout.CENTER);
    dialog.add(botoesPanel, BorderLayout.SOUTH);
    dialog.setVisible(true);
}

// ========== MÉTODO ESCALAR OS (ST) - ATUALIZADO ==========
private void escalarOrdemST() {
    int row = tabelaOrdensST.getSelectedRow();
    if (row < 0) {
        JOptionPane.showMessageDialog(this, "Selecione uma OS para escalar!");
        return;
    }
    
    int idOS = (int) modelOrdensST.getValueAt(row, 0);
    String nivelAtual = (String) modelOrdensST.getValueAt(row, 3);
    String status = (String) modelOrdensST.getValueAt(row, 4);
    
    if ("FECHADA".equals(status)) {
        JOptionPane.showMessageDialog(this, "Não é possível escalar uma OS já fechada!");
        return;
    }
    
    String proximoNivel;
    if ("1º Nível".equals(nivelAtual)) {
        proximoNivel = "2º Nível";
    } else if ("2º Nível".equals(nivelAtual)) {
        proximoNivel = "3º Nível";
    } else {
        JOptionPane.showMessageDialog(this, "Esta OS já está no nível máximo (3º Nível)!");
        return;
    }
    
    int confirm = JOptionPane.showConfirmDialog(this, 
        "Deseja escalar a OS #" + idOS + " para " + proximoNivel + "?\n\n" +
        "Motivo atual: " + modelOrdensST.getValueAt(row, 5),
        "Confirmar Escalação", JOptionPane.YES_NO_OPTION);
    
    if (confirm == JOptionPane.YES_OPTION) {
        OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
        if (os != null) {
            String motivoOriginal = os.getMotivo();
            os.setTipoNivel(proximoNivel);
            os.setMotivo(motivoOriginal + "\n[ESCALADO] para " + proximoNivel + " por " + usuarioLogado.getNomeCompleto());
            
            if (ordemServicoDAO.atualizar(os)) {
                JOptionPane.showMessageDialog(this, "OS #" + idOS + " escalada para " + proximoNivel + " com sucesso!");
                carregarOrdensST();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao escalar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
}

// ========== MÉTODO FECHAR OS (ST) - ATUALIZADO ==========
private void fecharOrdemST() {
    int row = tabelaOrdensST.getSelectedRow();
    if (row < 0) {
        JOptionPane.showMessageDialog(this, "Selecione uma OS para fechar!");
        return;
    }
    
    int idOS = (int) modelOrdensST.getValueAt(row, 0);
    String status = (String) modelOrdensST.getValueAt(row, 4);
    
    if ("FECHADA".equals(status)) {
        JOptionPane.showMessageDialog(this, "Esta OS já está fechada!");
        return;
    }
    
    JPanel panel = new JPanel(new GridBagLayout());
    GridBagConstraints gbc = new GridBagConstraints();
    gbc.insets = new Insets(5, 5, 5, 5);
    gbc.fill = GridBagConstraints.HORIZONTAL;
    
    gbc.gridx = 0; gbc.gridy = 0;
    panel.add(new JLabel("Descrição da Solução:*"), gbc);
    JTextArea txtSolucao = new JTextArea(5, 30);
    txtSolucao.setLineWrap(true);
    JScrollPane scrollSolucao = new JScrollPane(txtSolucao);
    gbc.gridy = 1;
    panel.add(scrollSolucao, gbc);
    
    gbc.gridy = 2;
    panel.add(new JLabel("Falha Identificada:*"), gbc);
    JComboBox<String> comboFalha = new JComboBox<>(new String[]{"CLIENTE", "MONITORAMENTO", "INSTALAÇÃO", "HARDWARE", "SOFTWARE"});
    gbc.gridy = 3;
    panel.add(comboFalha, gbc);
    
    int result = JOptionPane.showConfirmDialog(this, panel, 
        "Fechar Ordem de Serviço - ST #" + idOS, JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
    
    if (result == JOptionPane.OK_OPTION) {
        String solucao = txtSolucao.getText().trim();
        if (solucao.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Descrição da solução é obrigatória!");
            return;
        }
        
        String falha = (String) comboFalha.getSelectedItem();
        
        if (ordemServicoDAO.fecharOrdemServico(idOS, solucao, falha, usuarioLogado.getId())) {
            JOptionPane.showMessageDialog(this, "OS #" + idOS + " fechada com sucesso!");
            carregarOrdensST();
            
            // Opcional: registrar transação financeira se for uma OS de serviço pago
            int confirmTransacao = JOptionPane.showConfirmDialog(this,
                "Deseja registrar uma transação financeira para esta OS?",
                "Registrar Transação", JOptionPane.YES_NO_OPTION);
            
            if (confirmTransacao == JOptionPane.YES_OPTION) {
                registrarTransacaoParaOS(idOS);
            }
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao fechar OS!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
}

// ========== MÉTODO AUXILIAR PARA REGISTRAR TRANSAÇÃO ==========
private void registrarTransacaoParaOS(int idOS) {
    OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
    if (os == null) return;
    
    Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
    
    JPanel panel = new JPanel(new GridBagLayout());
    GridBagConstraints gbc = new GridBagConstraints();
    gbc.insets = new Insets(5, 5, 5, 5);
    gbc.fill = GridBagConstraints.HORIZONTAL;
    
    gbc.gridx = 0; gbc.gridy = 0;
    panel.add(new JLabel("Valor (R$):*"), gbc);
    JTextField txtValor = new JTextField(15);
    gbc.gridx = 1;
    panel.add(txtValor, gbc);
    
    gbc.gridx = 0; gbc.gridy = 1;
    panel.add(new JLabel("Forma de Pagamento:*"), gbc);
    JComboBox<String> comboForma = new JComboBox<>(new String[]{"DINHEIRO", "PIX", "CARTAO_DEBITO", "CARTAO_CREDITO", "TRANSFERENCIA"});
    gbc.gridx = 1;
    panel.add(comboForma, gbc);
    
    gbc.gridx = 0; gbc.gridy = 2;
    panel.add(new JLabel("Status:"), gbc);
    JComboBox<String> comboStatus = new JComboBox<>(new String[]{"PENDENTE", "RECEBIDO"});
    gbc.gridx = 1;
    panel.add(comboStatus, gbc);
    
    int result = JOptionPane.showConfirmDialog(this, panel, 
        "Registrar Transação - OS #" + idOS, JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE);
    
    if (result == JOptionPane.OK_OPTION) {
        try {
            double valor = Double.parseDouble(txtValor.getText().trim().replace(",", "."));
            if (valor <= 0) {
                JOptionPane.showMessageDialog(this, "Valor deve ser maior que zero!");
                return;
            }
            
            TransacaoFinanceira transacao = new TransacaoFinanceira();
            transacao.setTipo("ENTRADA");
            transacao.setNatureza("Manutenção");
            transacao.setFormaPagamento((String) comboForma.getSelectedItem());
            transacao.setValor(valor);
            transacao.setDescricao("Serviço - OS #" + idOS + " - Cliente: " + (cliente != null ? cliente.getNomeExibicao() : "N/A"));
            transacao.setStatus((String) comboStatus.getSelectedItem());
            transacao.setIdCliente(os.getIdCliente());
            transacao.setIdOrdemServico(idOS);
            transacao.setIdUsuarioRegistro(usuarioLogado.getId());
            
            if ("RECEBIDO".equals(transacao.getStatus())) {
                transacao.setDataPagamento(new Date());
            }
            
            if (transacaoDAO.inserir(transacao)) {
                JOptionPane.showMessageDialog(this, "Transação registrada com sucesso!");
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao registrar transação!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Valor inválido!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
}

private void atualizarBotoesST() {
    int row = tabelaOrdensST.getSelectedRow();
    boolean selecionado = row >= 0;
    
    if (selecionado) {
        String status = (String) modelOrdensST.getValueAt(row, 4);
        String nivel = (String) modelOrdensST.getValueAt(row, 3);
        
        btnAbrirOS.setEnabled(true);
        btnEscalarOS.setEnabled(("ABERTA".equals(status) || "EM_ATENDIMENTO".equals(status)) && 
                                ("1º Nível".equals(nivel) || "2º Nível".equals(nivel)));
        btnFecharOS.setEnabled(!"FECHADA".equals(status));
    } else {
        btnAbrirOS.setEnabled(true);
        btnEscalarOS.setEnabled(false);
        btnFecharOS.setEnabled(false);
    }
}