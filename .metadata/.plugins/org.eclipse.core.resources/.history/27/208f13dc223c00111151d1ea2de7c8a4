    private void configurarAtalhos() {
        // Atalho ESC
        getRootPane().registerKeyboardAction(e -> sairSistema(),
            KeyStroke.getKeyStroke(KeyEvent.VK_ESCAPE, 0),
            JComponent.WHEN_IN_FOCUSED_WINDOW);
        
