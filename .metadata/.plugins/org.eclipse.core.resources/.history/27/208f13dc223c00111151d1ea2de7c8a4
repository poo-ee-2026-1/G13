    private void atualizarDados() {
        // Simular atualização de dados (conectar ao ESP32 via WebSocket/HTTP)
        for (int i = 0; i < tableModel.getRowCount(); i++) {
            double tensaoAtual = 18.5 + Math.random() * 2.0; // Simulação
            double tensaoNominal = 19.0;
            
            // Atualizar menor e maior tensão
            int clienteId = i + 1;
            if (!menorTensao.containsKey(clienteId) || tensaoAtual < menorTensao.get(clienteId)) {
                menorTensao.put(clienteId, tensaoAtual);
            }
            if (!maiorTensao.containsKey(clienteId) || tensaoAtual > maiorTensao.get(clienteId)) {
                maiorTensao.put(clienteId, tensaoAtual);
            }
            
            // Determinar estado da rede
            String estadoRede;
            if (tensaoAtual > 0) {
                estadoRede = "ATIVO";
            } else {
                estadoRede = "INATIVO";
            }
            
            // Determinar situação da rede
            String situacaoRede;
            double diferenca = Math.abs(tensaoAtual - tensaoNominal);
            if (diferenca <= 1) {
                situacaoRede = "NORMAL";
                contadorAlertas.put(clienteId, 0);
                contadorCriticos.put(clienteId, 0);
            } else if (diferenca <= 3) {
                situacaoRede = "ALERTA";
                contadorAlertas.put(clienteId, contadorAlertas.getOrDefault(clienteId, 0) + 1);
                // Verificar se precisa abrir OS automática
                if (contadorAlertas.get(clienteId) > 3) {
                    abrirOSAutomatica(clienteId, "Múltiplos alertas de tensão");
                }
            } else {
                situacaoRede = "CRÍTICO";
                tocarAlertaSonoro();
                contadorCriticos.put(clienteId, contadorCriticos.getOrDefault(clienteId, 0) + 1);
                if (contadorCriticos.get(clienteId) > 3) {
                    abrirOSAutomatica(clienteId, "Tensão em nível crítico");
                }
            }
            
            // Atualizar tabela
            tableModel.setValueAt(estadoRede, i, 2);
            tableModel.setValueAt(String.format("%.2f", tensaoAtual), i, 3);
            tableModel.setValueAt(String.format("%.2f", maiorTensao.get(clienteId)), i, 4);
            tableModel.setValueAt(String.format("%.2f", menorTensao.get(clienteId)), i, 5);
            tableModel.setValueAt(situacaoRede, i, 6);
        }
    }
    
