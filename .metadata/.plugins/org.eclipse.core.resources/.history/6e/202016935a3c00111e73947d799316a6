    private void alterarTipoCliente() {
        boolean isFisica = comboTipo.getSelectedItem().equals("FISICA");
        txtNome.setEnabled(isFisica);
        txtSobrenome.setEnabled(isFisica);
        txtRazaoSocial.setEnabled(!isFisica);
        txtNomeFantasia.setEnabled(!isFisica);
        
        if (isFisica) {
            txtDocumento.setToolTipText("CPF (11 dígitos)");
        } else {
            txtDocumento.setToolTipText("CNPJ (14 dígitos)");
        }
    }
    
    private void carregarClientes() {
        tableModel.setRowCount(0);
        List<Cliente> clientes = clienteDAO.listarTodos();
        
        for (Cliente c : clientes) {
            String nomeExibicao = c.getTipo().equals("FISICA") ? 
                c.getNome() + " " + (c.getSobrenome() != null ? c.getSobrenome() : "") : 
                (c.getRazaoSocial() != null ? c.getRazaoSocial() : "");
            
            Object[] row = {
                c.getId(),
                c.getTipo(),
                c.getDocumento(),
                nomeExibicao,
                c.getTelefoneCompleto(),
                c.isEmMonitoramento() ? "SIM" : "NĂO",
                c.getIpCliente()
            };
            tableModel.addRow(row);
        }
    }
    
    private void buscarPorDocumento(String documento) {
        if (documento.isEmpty()) {
            carregarClientes();
            return;
        }
        
        Cliente cliente = clienteDAO.buscarPorDocumento(documento);
        tableModel.setRowCount(0);
        
        if (cliente != null) {
            String nomeExibicao = cliente.getTipo().equals("FISICA") ? 
                cliente.getNome() + " " + (cliente.getSobrenome() != null ? cliente.getSobrenome() : "") : 
                (cliente.getRazaoSocial() != null ? cliente.getRazaoSocial() : "");
            
            Object[] row = {
                cliente.getId(),
                cliente.getTipo(),
                cliente.getDocumento(),
                nomeExibicao,
                cliente.getTelefoneCompleto(),
                cliente.isEmMonitoramento() ? "SIM" : "NĂO",
                cliente.getIpCliente()
            };
            tableModel.addRow(row);
            carregarClienteNoFormulario(cliente);
        } else {
            JOptionPane.showMessageDialog(this, "Cliente năo encontrado!");
            carregarClientes();
        }
    }
    
    private void carregarClienteSelecionado() {
        int row = tabelaClientes.getSelectedRow();
        if (row >= 0) {
            int id = (int) tableModel.getValueAt(row, 0);
            Cliente cliente = clienteDAO.buscarPorId(id);
            if (cliente != null) {
                carregarClienteNoFormulario(cliente);
            }
        }
    }
    
    private void carregarClienteNoFormulario(Cliente cliente) {
        txtId.setText(String.valueOf(cliente.getId()));
        comboTipo.setSelectedItem(cliente.getTipo());
        txtDocumento.setText(cliente.getDocumento());
        txtNome.setText(cliente.getNome() != null ? cliente.getNome() : "");
        txtSobrenome.setText(cliente.getSobrenome() != null ? cliente.getSobrenome() : "");
        txtRazaoSocial.setText(cliente.getRazaoSocial() != null ? cliente.getRazaoSocial() : "");
        txtNomeFantasia.setText(cliente.getNomeFantasia() != null ? cliente.getNomeFantasia() : "");
        txtLogradouro.setText(cliente.getLogradouro() != null ? cliente.getLogradouro() : "");
        txtNumero.setText(cliente.getNumero() != null ? cliente.getNumero() : "");
        txtBairro.setText(cliente.getBairro() != null ? cliente.getBairro() : "");
        txtCidade.setText(cliente.getCidade() != null ? cliente.getCidade() : "");
        txtEstado.setText(cliente.getEstado() != null ? cliente.getEstado() : "");
        txtCep.setText(cliente.getCep() != null ? cliente.getCep() : "");
        txtTelefoneDDD.setText(cliente.getTelefoneDDD() != null ? cliente.getTelefoneDDD() : "");
        txtTelefoneNumero.setText(cliente.getTelefoneNumero() != null ? cliente.getTelefoneNumero() : "");
        txtIpCliente.setText(cliente.getIpCliente() != null ? cliente.getIpCliente() : "");
        chkMonitoramento.setSelected(cliente.isEmMonitoramento());
        
        alterarTipoCliente();
    }
    
    private void inserirCliente() {
        if (!validarCampos()) return;
        
        Cliente cliente = new Cliente();
        preencherCliente(cliente);
        
        if (clienteDAO.inserir(cliente)) {
            JOptionPane.showMessageDialog(this, "Cliente inserido com sucesso!");
            carregarClientes();
            limparFormulario();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao inserir cliente!\nVerifique se o documento já está cadastrado.", 
                                        "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void atualizarCliente() {
        if (txtId.getText().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente para atualizar!");
            return;
        }
        
        if (!validarCampos()) return;
        
        Cliente cliente = new Cliente();
        cliente.setId(Integer.parseInt(txtId.getText()));
        preencherCliente(cliente);
        
        if (clienteDAO.atualizar(cliente)) {
            JOptionPane.showMessageDialog(this, "Cliente atualizado com sucesso!");
            carregarClientes();
            limparFormulario();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao atualizar cliente!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void excluirCliente() {
        if (txtId.getText().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente para excluir!");
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Deseja realmente excluir este cliente?\nTodas as mediçőes e equipamentos serăo removidos!", 
            "Confirmar exclusăo", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            int id = Integer.parseInt(txtId.getText());
            if (clienteDAO.excluir(id)) {
                JOptionPane.showMessageDialog(this, "Cliente excluído com sucesso!");
                carregarClientes();
                limparFormulario();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao excluir cliente!\nVerifique se o cliente possui ordens de serviço associadas.", 
                                            "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void preencherCliente(Cliente cliente) {
        cliente.setTipo((String) comboTipo.getSelectedItem());
        cliente.setDocumento(txtDocumento.getText().trim());
        cliente.setNome(txtNome.getText().trim());
        cliente.setSobrenome(txtSobrenome.getText().trim());
        cliente.setRazaoSocial(txtRazaoSocial.getText().trim());
        cliente.setNomeFantasia(txtNomeFantasia.getText().trim());
        cliente.setLogradouro(txtLogradouro.getText().trim());
        cliente.setNumero(txtNumero.getText().trim());
        cliente.setBairro(txtBairro.getText().trim());
        cliente.setCidade(txtCidade.getText().trim());
        cliente.setEstado(txtEstado.getText().trim());
        cliente.setCep(txtCep.getText().trim());
        cliente.setTelefoneDDD(txtTelefoneDDD.getText().trim());
        cliente.setTelefoneNumero(txtTelefoneNumero.getText().trim());
        cliente.setIpCliente(txtIpCliente.getText().trim());
        cliente.setEmMonitoramento(chkMonitoramento.isSelected());
    }
    
    private boolean validarCampos() {
        String tipo = (String) comboTipo.getSelectedItem();
        String documento = txtDocumento.getText().trim();
        
        if (documento.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Documento é obrigatório!");
            return false;
        }
        
        if (tipo.equals("FISICA")) {
            if (!ValidadorCPF.validar(documento)) {
                JOptionPane.showMessageDialog(this, "CPF inválido!");
                return false;
            }
            if (txtNome.getText().trim().isEmpty()) {
                JOptionPane.showMessageDialog(this, "Nome é obrigatório!");
                return false;
            }
        } else {
            if (!ValidadorCNPJ.validar(documento)) {
                JOptionPane.showMessageDialog(this, "CNPJ inválido!");
                return false;
            }
            if (txtRazaoSocial.getText().trim().isEmpty()) {
                JOptionPane.showMessageDialog(this, "Razăo Social é obrigatória!");
                return false;
            }
        }
        
        if (txtLogradouro.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Logradouro é obrigatório!");
            return false;
        }
        
        if (txtNumero.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Número é obrigatório!");
            return false;
        }
        
        if (txtBairro.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Bairro é obrigatório!");
            return false;
        }
        
        if (txtCidade.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Cidade é obrigatória!");
            return false;
        }
        
        if (txtEstado.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Estado é obrigatório!");
            return false;
        }
        
        String ddd = txtTelefoneDDD.getText().trim();
        if (ddd.isEmpty() || ddd.length() != 2 || !ddd.matches("\\d+")) {
            JOptionPane.showMessageDialog(this, "DDD deve ter 2 dígitos numéricos!");
            return false;
        }
        
        String telefone = txtTelefoneNumero.getText().trim();
        if (telefone.isEmpty() || (telefone.length() < 8 || telefone.length() > 9) || !telefone.matches("\\d+")) {
            JOptionPane.showMessageDialog(this, "Telefone deve ter 8 ou 9 dígitos numéricos!");
            return false;
        }
        
        String ip = txtIpCliente.getText().trim();
        if (ip.isEmpty()) {
            JOptionPane.showMessageDialog(this, "IP do cliente é obrigatório!");
            return false;
        }
        
        // Validaçăo simples de IP
        String ipPattern = "^([0-9]{1,3}\\.){3}[0-9]{1,3}$";
        if (!ip.matches(ipPattern)) {
            JOptionPane.showMessageDialog(this, "IP inválido! Formato esperado: xxx.xxx.xxx.xxx");
            return false;
        }
        
        return true;
    }
    
    private void limparFormulario() {
        txtId.setText("");
        comboTipo.setSelectedIndex(0);
        txtDocumento.setText("");
        txtNome.setText("");
        txtSobrenome.setText("");
        txtRazaoSocial.setText("");
        txtNomeFantasia.setText("");
        txtLogradouro.setText("");
        txtNumero.setText("");
        txtBairro.setText("");
        txtCidade.setText("");
        txtEstado.setText("");
        txtCep.setText("");
        txtTelefoneDDD.setText("");
        txtTelefoneNumero.setText("");
        txtIpCliente.setText("");
        chkMonitoramento.setSelected(false);
        txtDocumento.requestFocus();
        
        alterarTipoCliente();
    }
