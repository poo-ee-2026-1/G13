    private JPanel criarPainelSelecaoProdutos() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBorder(BorderFactory.createTitledBorder("Produtos para Instalação"));
        
        JPanel panelTopo = new JPanel(new FlowLayout(FlowLayout.LEFT));
        panelTopo.add(new JLabel("Produto:"));
        JComboBox<String> comboProduto = new JComboBox<>();
        comboProduto.setPreferredSize(new Dimension(350, 25));
        
        List<ProdutoEstoque> produtos = produtoEstoqueDAO.listarAtivos();
        for (ProdutoEstoque p : produtos) {
            comboProduto.addItem(p.getId() + " - " + p.getNomeCompleto() + " (Estoque: " + p.getQuantidade() + ")");
        }
        
        JSpinner spQuantidade = new JSpinner(new SpinnerNumberModel(1, 1, 999, 1));
        spQuantidade.setPreferredSize(new Dimension(80, 25));
        
        JButton btnAdicionar = new JButton("Adicionar Produto");
        
        panelTopo.add(comboProduto);
        panelTopo.add(new JLabel("Quantidade:"));
        panelTopo.add(spQuantidade);
        panelTopo.add(btnAdicionar);
        
        String[] colunas = {"ID Produto", "Produto", "Quantidade", "Preço Unitário", "Subtotal"};
        modelProdutosSelecionados = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        tabelaProdutosSelecionados = new JTable(modelProdutosSelecionados);
        tabelaProdutosSelecionados.getColumnModel().getColumn(0).setPreferredWidth(50);
        tabelaProdutosSelecionados.getColumnModel().getColumn(1).setPreferredWidth(300);
        tabelaProdutosSelecionados.getColumnModel().getColumn(2).setPreferredWidth(80);
        tabelaProdutosSelecionados.getColumnModel().getColumn(3).setPreferredWidth(100);
        tabelaProdutosSelecionados.getColumnModel().getColumn(4).setPreferredWidth(100);
        
        JScrollPane scroll = new JScrollPane(tabelaProdutosSelecionados);
        
        JButton btnRemover = new JButton("Remover Selecionado");
        JPanel panelBotoes = new JPanel();
        panelBotoes.add(btnRemover);
        
        btnAdicionar.addActionListener(e -> {
            if (comboProduto.getSelectedIndex() == -1) return;
            
            String selected = (String) comboProduto.getSelectedItem();
            int idProduto = Integer.parseInt(selected.split(" - ")[0]);
            int quantidade = (int) spQuantidade.getValue();
            
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(idProduto);
            if (produto == null) return;
            
            if (produto.getQuantidade() < quantidade) {
                JOptionPane.showMessageDialog(panel, 
                    "Estoque insuficiente!\nDisponível: " + produto.getQuantidade() + 
                    "\nSolicitado: " + quantidade, 
                    "Erro", JOptionPane.ERROR_MESSAGE);
                return;
            }
            
            InstalacaoProduto existente = produtosSelecionados.stream()
                .filter(ip -> ip.getIdProduto() == idProduto)
                .findFirst()
                .orElse(null);
            
            if (existente != null) {
                existente.setQuantidade(existente.getQuantidade() + quantidade);
                existente.setSubtotal(existente.getQuantidade() * existente.getPrecoUnitario());
                
                for (int i = 0; i < modelProdutosSelecionados.getRowCount(); i++) {
                    if ((int) modelProdutosSelecionados.getValueAt(i, 0) == idProduto) {
                        modelProdutosSelecionados.setValueAt(existente.getQuantidade(), i, 2);
                        modelProdutosSelecionados.setValueAt(String.format("R$ %.2f", existente.getSubtotal()), i, 4);
                        break;
                    }
                }
            } else {
                InstalacaoProduto item = new InstalacaoProduto();
                item.setIdProduto(idProduto);
                item.setQuantidade(quantidade);
                item.setPrecoUnitario(produto.getPrecoVenda());
                item.setSubtotal(quantidade * produto.getPrecoVenda());
                produtosSelecionados.add(item);
                
                Object[] row = {
                    idProduto,
                    produto.getNomeCompleto(),
                    quantidade,
                    String.format("R$ %.2f", produto.getPrecoVenda()),
                    String.format("R$ %.2f", item.getSubtotal())
                };
                modelProdutosSelecionados.addRow(row);
            }
            
            double total = produtosSelecionados.stream().mapToDouble(InstalacaoProduto::getSubtotal).sum();
            txtValorOrcamento.setText(String.format("%.2f", total));
        });
        
        btnRemover.addActionListener(e -> {
            int row = tabelaProdutosSelecionados.getSelectedRow();
            if (row >= 0) {
                int idProduto = (int) modelProdutosSelecionados.getValueAt(row, 0);
                produtosSelecionados.removeIf(ip -> ip.getIdProduto() == idProduto);
                modelProdutosSelecionados.removeRow(row);
                
                double total = produtosSelecionados.stream().mapToDouble(InstalacaoProduto::getSubtotal).sum();
                txtValorOrcamento.setText(String.format("%.2f", total));
            }
        });
        
        panel.add(panelTopo, BorderLayout.NORTH);
        panel.add(scroll, BorderLayout.CENTER);
        panel.add(panelBotoes, BorderLayout.SOUTH);
        
        return panel;
    }
    
