                            item.getPrecoUnitario(), item.getSubtotal()));
                    }
                }
            }
            
            textArea.setEditable(false);
            
            JOptionPane.showMessageDialog(this, new JScrollPane(textArea), 
                "Detalhes do Orçamento", JOptionPane.INFORMATION_MESSAGE);
        }
    }
    
