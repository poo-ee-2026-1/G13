        JLabel lblTensaoMedia = new JLabel("Média: 0 V");
        JLabel lblTensaoMin = new JLabel("Mínima: 0 V");
        JLabel lblTensaoMax = new JLabel("Máxima: 0 V");
        JLabel lblAlertas = new JLabel("Alertas: 0");
