    private JPanel criarPainelAprovarOrcamento() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        
        String[] colunas = {"ID", "Cliente", "Valor (R$)", "Data", "Descrição"};
        DefaultTableModel modelPendentes = new DefaultTableModel(colunas, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        
        JTable tabelaPendentes = new JTable(modelPendentes);
        
        carregarOrcamentosPendentes(modelPendentes);
        
        JButton btnAprovar = new JButton("Aprovar Orçamento e Gerar Ordem de Instalação");
        btnAprovar.addActionListener(e -> {
            int row = tabelaPendentes.getSelectedRow();
            if (row >= 0) {
                int idOrcamento = (int) modelPendentes.getValueAt(row, 0);
                double valor = (double) modelPendentes.getValueAt(row, 2);
                
                aprovarOrcamento(idOrcamento, valor);
                
                modelPendentes.setRowCount(0);
                carregarOrcamentosPendentes(modelPendentes);
            } else {
                JOptionPane.showMessageDialog(panel, "Selecione um orçamento para aprovar!");
            }
        });
        
        panel.add(new JScrollPane(tabelaPendentes), BorderLayout.CENTER);
        panel.add(btnAprovar, BorderLayout.SOUTH);
        
        return panel;
    }
    
    private void carregarOrcamentosPendentes(DefaultTableModel model) {
        List<Atendimento> orcamentos = atendimentoDAO.listarPorTipo("ORCAMENTO");
        orcamentos = orcamentos.stream()
            .filter(a -> "PENDENTE".equals(a.getStatus()))
            .toList();
        
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        for (Atendimento a : orcamentos) {
            Cliente c = clienteDAO.buscarPorId(a.getIdCliente());
            if (c != null) {
                Object[] row = {
                    a.getId(),
                    c.getNomeExibicao(),
                    extrairValorOrcamento(a.getDescricao()),
                    sdf.format(a.getDataAbertura()),
                    a.getAssunto()
                };
                model.addRow(row);
            }
        }
    }
    
    private void carregarClientesCombos() {
        comboClienteOrcamento.removeAllItems();
        
        List<Cliente> clientes = clienteDAO.listarTodos();
        for (Cliente c : clientes) {
            String item = c.getId() + " - " + c.getNomeExibicao();
            comboClienteOrcamento.addItem(item);
        }
    }
    
    private void carregarOrcamentos() {
        modelOrcamentos.setRowCount(0);
        List<Atendimento> orcamentos = atendimentoDAO.listarPorTipo("ORCAMENTO");
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (Atendimento a : orcamentos) {
            Cliente c = clienteDAO.buscarPorId(a.getIdCliente());
            if (c != null) {
                Object[] row = {
                    a.getId(),
                    c.getNomeExibicao(),
                    extrairValorOrcamento(a.getDescricao()),
                    a.getStatus(),
                    sdf.format(a.getDataAbertura()),
                    a.getAssunto()
                };
                modelOrcamentos.addRow(row);
            }
        }
    }
    
    private void carregarInstalacoes() {
        modelInstalacoes.setRowCount(0);
        List<Atendimento> instalacoes = atendimentoDAO.listarPorTipo("ORDEM_INSTALACAO");
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (Atendimento a : instalacoes) {
            Cliente c = clienteDAO.buscarPorId(a.getIdCliente());
            if (c != null) {
                String osVinculada = a.getIdOrdemServicoVinculada() > 0 ? "OS #" + a.getIdOrdemServicoVinculada() : "---";
                Object[] row = {
                    a.getId(),
                    c.getNomeExibicao(),
                    extrairValorOrcamento(a.getDescricao()),
                    a.getStatus(),
                    sdf.format(a.getDataAbertura()),
                    a.getDataConclusao() != null ? sdf.format(a.getDataConclusao()) : "---",
                    osVinculada
                };
                modelInstalacoes.addRow(row);
            }
        }
    }
    
    private double extrairValorOrcamento(String descricao) {
        if (descricao != null) {
            int idx = descricao.indexOf("VALOR TOTAL: R$ ");
            if (idx >= 0) {
                try {
                    String valorStr = descricao.substring(idx + 15);
                    int endIdx = valorStr.indexOf("\n");
                    if (endIdx > 0) {
                        valorStr = valorStr.substring(0, endIdx);
                    }
                    valorStr = valorStr.replace(",", ".").trim();
                    return Double.parseDouble(valorStr);
                } catch (Exception e) {
                    // Ignorar
                }
            }
        }
        return 0;
    }
    
    private void gerarOrcamento() {
        if (comboClienteOrcamento.getSelectedIndex() == -1) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente!");
            return;
        }
        
        String valorStr = txtValorOrcamento.getText().trim().replace(",", ".");
        double valor;
        try {
            valor = Double.parseDouble(valorStr);
            if (valor <= 0) {
                JOptionPane.showMessageDialog(this, "Adicione pelo menos um produto ao orçamento!");
                return;
            }
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Valor inválido!");
            return;
        }
        
        String descricaoResumida = txtDescricaoOrcamento.getText().trim();
        if (descricaoResumida.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Descrição resumida é obrigatória!");
            return;
        }
        
        String detalhes = txtDetalhesOrcamento.getText().trim();
        
        StringBuilder sbDescricao = new StringBuilder();
        sbDescricao.append("VALOR TOTAL: R$ ").append(String.format("%.2f", valor)).append("\n");
        sbDescricao.append("DESCRIÇÃO: ").append(descricaoResumida).append("\n");
        sbDescricao.append("PRODUTOS:\n");
        for (InstalacaoProduto item : produtosSelecionados) {
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
            if (produto != null) {
                sbDescricao.append("- ").append(produto.getNomeCompleto())
                         .append(": ").append(item.getQuantidade()).append(" x R$ ")
                         .append(String.format("%.2f", item.getPrecoUnitario()))
                         .append(" = R$ ").append(String.format("%.2f", item.getSubtotal())).append("\n");
            }
        }
        if (!detalhes.isEmpty()) {
            sbDescricao.append("OBSERVAÇÕES: ").append(detalhes).append("\n");
        }
        
        String selected = (String) comboClienteOrcamento.getSelectedItem();
        int idCliente = Integer.parseInt(selected.split(" - ")[0]);
        
        Atendimento orcamento = new Atendimento();
        orcamento.setIdCliente(idCliente);
        orcamento.setTipo("ORCAMENTO");
        orcamento.setAssunto("Orçamento - " + descricaoResumida);
        orcamento.setDescricao(sbDescricao.toString());
        orcamento.setPrioridade("MEDIA");
        orcamento.setIdUsuarioAbertura(usuarioLogado.getId());
        
        if (atendimentoDAO.inserir(orcamento)) {
            for (InstalacaoProduto item : produtosSelecionados) {
                item.setIdOrdemInstalacao(orcamento.getId());
                instalacaoProdutoDAO.inserir(item);
            }
            
            JOptionPane.showMessageDialog(this, "Orçamento gerado com sucesso!\nID: " + orcamento.getId());
            
            txtValorOrcamento.setText("0,00");
            txtDescricaoOrcamento.setText("");
            txtDetalhesOrcamento.setText("");
            produtosSelecionados.clear();
            modelProdutosSelecionados.setRowCount(0);
            
            carregarOrcamentos();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao gerar orçamento!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void aprovarOrcamento(int idOrcamento, double valor) {
        Atendimento orcamento = atendimentoDAO.buscarPorId(idOrcamento);
        if (orcamento == null) return;
        
        List<InstalacaoProduto> produtosOrcamento = instalacaoProdutoDAO.listarPorOrdemInstalacao(idOrcamento);
        
        Cliente cliente = clienteDAO.buscarPorId(orcamento.getIdCliente());
        if (cliente == null) return;
        
        for (InstalacaoProduto item : produtosOrcamento) {
            ProdutoEstoque produto = produtoEstoqueDAO.buscarPorId(item.getIdProduto());
            if (produto == null || produto.getQuantidade() < item.getQuantidade()) {
                JOptionPane.showMessageDialog(this,
                    "Estoque insuficiente para o produto: " + (produto != null ? produto.getNomeCompleto() : "ID: " + item.getIdProduto()) + "\n" +
                    "Disponível: " + (produto != null ? produto.getQuantidade() : 0) + 
                    "\nSolicitado: " + item.getQuantidade(),
                    "Erro", JOptionPane.ERROR_MESSAGE);
                return;
            }
        }
        
        int confirm = JOptionPane.showConfirmDialog(this,
            "Aprovar orçamento para o cliente " + cliente.getNomeExibicao() + "?\n" +
            "Valor: R$ " + String.format("%.2f", valor) + "\n\n" +
            "Uma Ordem de Instalação será gerada e os produtos serão baixados do estoque.",
            "Aprovar Orçamento", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            for (InstalacaoProduto item : produtosOrcamento) {
                boolean baixaOk = produtoEstoqueDAO.darBaixaEstoque(
                    item.getIdProduto(), 
                    item.getQuantidade(), 
                    "INSTALACAO", 
                    idOrcamento,
                    usuarioLogado.getId()
                );
                
                if (!baixaOk) {
                    JOptionPane.showMessageDialog(this, "Erro ao dar baixa no estoque do produto ID: " + item.getIdProduto(),
                        "Erro", JOptionPane.ERROR_MESSAGE);
                    return;
                }
            }
            
            Atendimento instalacao = new Atendimento();
            instalacao.setIdCliente(cliente.getId());
            instalacao.setTipo("ORDEM_INSTALACAO");
            instalacao.setAssunto("Instalação - Orçamento #" + idOrcamento);
            instalacao.setDescricao(orcamento.getDescricao() + "\n\nSTATUS: Aguardando instalação técnica.");
            instalacao.setPrioridade("ALTA");
            instalacao.setIdUsuarioAbertura(usuarioLogado.getId());
            
            if (atendimentoDAO.inserir(instalacao)) {
                // Excluir os registros antigos e inserir os novos com o novo ID
                instalacaoProdutoDAO.excluirPorOrdemInstalacao(idOrcamento);
                for (InstalacaoProduto item : produtosOrcamento) {
                    item.setIdOrdemInstalacao(instalacao.getId());
                    instalacaoProdutoDAO.inserir(item);
                }
                
                orcamento.setStatus("CONCLUIDO");
                orcamento.setDataConclusao(new Date());
                orcamento.setIdUsuarioAtendimento(usuarioLogado.getId());
                atendimentoDAO.atualizar(orcamento);
                
                TransacaoFinanceira transacao = new TransacaoFinanceira();
                transacao.setTipo("ENTRADA");
                transacao.setNatureza("Instalação");
                transacao.setFormaPagamento("A_DEFINIR");
                transacao.setValor(valor);
                transacao.setDescricao("Instalação - Orçamento #" + idOrcamento + " - Cliente: " + cliente.getNomeExibicao());
                transacao.setStatus("PENDENTE");
                transacao.setIdCliente(cliente.getId());
                transacao.setIdUsuarioRegistro(usuarioLogado.getId());
                transacaoDAO.inserir(transacao);
                
                JOptionPane.showMessageDialog(this,
                    "Orçamento aprovado!\n\n" +
                    "Ordem de Instalação #" + instalacao.getId() + " criada.\n" +
                    "Produtos baixados do estoque.\n" +
                    "Transação financeira registrada (PENDENTE).\n\n" +
                    "Agora o técnico deve realizar a instalação e concluir a ordem.");
                
                carregarInstalacoes();
                carregarOrcamentos();
            } else {
                JOptionPane.showMessageDialog(this, "Erro ao criar Ordem de Instalação!", "Erro", JOptionPane.ERROR_MESSAGE);
            }
        }
    }
    
    private void recusarOrcamento() {
        int row = tabelaOrcamentos.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione um orçamento para recusar!");
            return;
        }
        
        int id = (int) modelOrcamentos.getValueAt(row, 0);
        String status = (String) modelOrcamentos.getValueAt(row, 3);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Este orçamento não está pendente!");
            return;
        }
        
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Deseja recusar este orçamento?", 
            "Recusar Orçamento", JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            Atendimento a = atendimentoDAO.buscarPorId(id);
            if (a != null) {
                a.setStatus("CANCELADO");
                a.setDataConclusao(new Date());
                a.setIdUsuarioAtendimento(usuarioLogado.getId());
                if (atendimentoDAO.atualizar(a)) {
                    JOptionPane.showMessageDialog(this, "Orçamento recusado!");
                    carregarOrcamentos();
                }
            }
        }
    }
    
    private void concluirInstalacao() {
        int row = tabelaInstalacoes.getSelectedRow();
        if (row < 0) {
            JOptionPane.showMessageDialog(this, "Selecione uma ordem de instalação para concluir!");
            return;
        }
        
        int id = (int) modelInstalacoes.getValueAt(row, 0);
        String status = (String) modelInstalacoes.getValueAt(row, 3);
        
        if (!"PENDENTE".equals(status)) {
            JOptionPane.showMessageDialog(this, "Esta instalação já foi concluída!");
            return;
        }
        
        Atendimento instalacao = atendimentoDAO.buscarPorId(id);
        if (instalacao == null) return;
        
        var equipamentos = equipamentoDAO.buscarPorCliente(instalacao.getIdCliente());
        
        OrdemServico os = new OrdemServico();
        os.setIdCliente(instalacao.getIdCliente());
        os.setIdEquipamento(equipamentos.isEmpty() ? 0 : equipamentos.get(0).getId());
        os.setTipoNivel("3º Nível");
        os.setStatus("ABERTA");
        os.setMotivo("INSTALAÇÃO - " + instalacao.getAssunto());
        os.setDataAbertura(new Date());
        os.setIdUsuarioAbertura(usuarioLogado.getId());
        
        if (ordemServicoDAO.inserir(os)) {
            instalacao.setStatus("CONCLUIDO");
            instalacao.setDataConclusao(new Date());
            instalacao.setIdUsuarioAtendimento(usuarioLogado.getId());
            instalacao.setIdOrdemServicoVinculada(os.getId());
            atendimentoDAO.atualizar(instalacao);
            
            JOptionPane.showMessageDialog(this,
                "Instalação concluída!\n" +
                "OS #" + os.getId() + " (3º Nível) criada para o técnico realizar a instalação.");
            
            carregarInstalacoes();
        } else {
            JOptionPane.showMessageDialog(this, "Erro ao criar OS para instalação!", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
