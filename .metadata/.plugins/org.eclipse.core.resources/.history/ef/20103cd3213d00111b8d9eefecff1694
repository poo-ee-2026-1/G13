    private void carregarClientesCombo(JComboBox<String> combo) {
        combo.removeAllItems();
        combo.addItem("SELECIONE");
        List<Cliente> clientes = clienteDAO.listarTodos();
        for (Cliente c : clientes) {
            combo.addItem(c.getId() + " - " + c.getNomeExibicao());
        }
    }
    
    private void carregarOrcamentos() {
        modelOrcamentos.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        Object[] row = {1, "Cliente Exemplo", "Instalação de Sistema", "1500,00", "PENDENTE", sdf.format(new Date())};
        modelOrcamentos.addRow(row);
    }
    
    private void filtrarOrcamentos() {
        carregarOrcamentos();
    }
    
    private void salvarOrcamento(JComboBox<String> comboCliente) {
        if (comboCliente.getSelectedIndex() == 0 || "SELECIONE".equals(comboCliente.getSelectedItem())) {
            JOptionPane.showMessageDialog(this, "Selecione um cliente!");
            return;
        }
        
        String descricao = txtDescricaoOrcamento.getText().trim();
        if (descricao.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Descrição é obrigatória!");
            return;
        }
        
        String valorStr = txtValorOrcamento.getText().trim();
        if (valorStr.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Valor é obrigatório!");
            return;
        }
        
        try {
            double valor = Double.parseDouble(valorStr.replace(",", "."));
            
            JOptionPane.showMessageDialog(this, 
                "Orçamento salvo com sucesso!\n\n" +
                "Cliente: " + comboCliente.getSelectedItem() + "\n" +
                "Descrição: " + descricao + "\n" +
                "Valor: R$ " + String.format("%.2f", valor),
                "Sucesso", JOptionPane.INFORMATION_MESSAGE);
            
            txtDescricaoOrcamento.setText("");
            txtValorOrcamento.setText("");
            carregarOrcamentos();
            
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Valor inválido! Use formato: 1234.56", "Erro", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    private void carregarOrdensInstalacao() {
        modelOrdensInstalacao.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        List<OrdemServico> ordensInstalacao = ordemServicoDAO.listarOrdensInstalacao();
        
        for (OrdemServico os : ordensInstalacao) {
            Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
            String nomeCliente = cliente != null ? cliente.getNomeExibicao() : "N/A";
            String nivel = os.getTipoNivel() != null ? os.getTipoNivel() : "1º Nível";
            String statusExibicao = getStatusExibicao(os.getStatus());
            
            Object[] row = {
                os.getId(),
                nomeCliente,
                nivel,
                statusExibicao,
                os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                String.format("%.2f", os.getValorTotal()),
                os.getDataAgendamento() != null ? os.getDataAgendamento() : "",
                os.getEnderecoInstalacao() != null ? os.getEnderecoInstalacao() : ""
            };
            modelOrdensInstalacao.addRow(row);
        }
        
        lblStatusInfo.setText("✅ Sistema de OS - Instalação | Total de OS: " + ordensInstalacao.size() + " | Usuário: " + usuarioLogado.getNomeCompleto());
    }
    
    private String getStatusExibicao(String status) {
        switch (status) {
            case "ABERTA": return "ABERTA";
            case "EM_ATENDIMENTO": return "EM ATENDIMENTO";
            case "FECHADA": return "FECHADA";
            default: return status;
        }
    }
    
    private void filtrarOrdensInstalacao() {
        String nivel = (String) comboFiltroNivelInstalacao.getSelectedItem();
        String status = (String) comboFiltroStatusInstalacao.getSelectedItem();
        String clienteSelecionado = (String) comboClienteInstalacao.getSelectedItem();
        
        List<OrdemServico> ordens = ordemServicoDAO.listarOrdensInstalacao();
        
        if (!"TODOS".equals(nivel)) {
            ordens = ordens.stream()
                .filter(os -> os.getTipoNivel() != null && os.getTipoNivel().equals(nivel))
                .toList();
        }
        
        if (!"TODAS".equals(status)) {
            ordens = ordens.stream()
                .filter(os -> os.getStatus() != null && os.getStatus().equals(status))
                .toList();
        }
        
        if (clienteSelecionado != null && !"SELECIONE".equals(clienteSelecionado)) {
            int idCliente = Integer.parseInt(clienteSelecionado.split(" - ")[0]);
            ordens = ordens.stream()
                .filter(os -> os.getIdCliente() == idCliente)
                .toList();
        }
        
        modelOrdensInstalacao.setRowCount(0);
        SimpleDateFormat sdf = new SimpleDateFormat("dd/MM/yyyy");
        
        for (OrdemServico os : ordens) {
            Cliente cliente = clienteDAO.buscarPorId(os.getIdCliente());
            String nomeCliente = cliente != null ? cliente.getNomeExibicao() : "N/A";
            String nivelOS = os.getTipoNivel() != null ? os.getTipoNivel() : "1º Nível";
            String statusExibicao = getStatusExibicao(os.getStatus());
            
            Object[] row = {
                os.getId(),
                nomeCliente,
                nivelOS,
                statusExibicao,
                os.getDataAbertura() != null ? sdf.format(os.getDataAbertura()) : "",
                String.format("%.2f", os.getValorTotal()),
                os.getDataAgendamento() != null ? os.getDataAgendamento() : "",
                os.getEnderecoInstalacao() != null ? os.getEnderecoInstalacao() : ""
            };
            modelOrdensInstalacao.addRow(row);
        }
    }
    
    private void carregarDetalhesInstalacao() {
        int row = tabelaOrdensInstalacao.getSelectedRow();
        if (row >= 0) {
            int idOS = (int) modelOrdensInstalacao.getValueAt(row, 0);
            OrdemServico os = ordemServicoDAO.buscarPorId(idOS);
            
            if (os != null) {
                txtEnderecoInstalacao.setText(os.getEnderecoInstalacao() != null ? os.getEnderecoInstalacao() : "");
                txtDataAgendamento.setText(os.getDataAgendamento() != null ? os.getDataAgendamento() : "");
                txtDescricaoInstalacao.setText(os.getDescricaoSolucao() != null ? os.getDescricaoSolucao() : "");
                txtObservacoesInstalacao.setText(os.getObservacoes() != null ? os.getObservacoes() : "");
                txtValorTotalInstalacao.setText(String.format("%.2f", os.getValorTotal()));
                
                carregarProdutosInstalacao(idOS);
            }
        } else {
            limparCamposInstalacao();
        }
    }
    
    private void carregarProdutosInstalacao(int idOrdemInstalacao) {
        modelProdutosSelecionados.setRowCount(0);
        
        List<InstalacaoProduto> itens = instalacaoProdutoDAO.listarPorOrdemInstalacao(idOrdemInstalacao);
        
        for (InstalacaoProduto item : itens) {
            ProdutoEstoque produto = produtoDAO.buscarPorId(item.getIdProduto());
            String nomeProduto = produto != null ? produto.getNome() : "Produto ID: " + item.getIdProduto();
            
            Object[] row = {
                nomeProduto,
                item.getQuantidade(),
                String.format("%.2f", item.getPrecoUnitario()),
                String.format("%.2f", item.getSubtotal())
            };
            modelProdutosSelecionados.addRow(row);
        }
    }
    
    private void limparCamposInstalacao() {
        txtEnderecoInstalacao.setText("");
        txtDataAgendamento.setText("");
        txtDescricaoInstalacao.setText("");
        txtObservacoesInstalacao.setText("");
        txtValorTotalInstalacao.setText("0,00");
        modelProdutosSelecionados.setRowCount(0);
    }
    
